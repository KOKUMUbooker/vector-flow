@page "/not-found"
@layout Features.Layout.MainLayout
@inject NavigationManager Nav

<PageTitle>404 — VectorFlow</PageTitle>

<div class="auth-shell">
    <div class="auth-form-side">
        <div class="auth-form-card">

            <div class="error-code">404</div>

            <MudText Typo="Typo.h3" Class="form-title mt-4 mb-2">
                Page not found
            </MudText>
            <MudText Typo="Typo.body1" Class="form-subtitle mb-8">
                The page you're looking for doesn't exist, was moved, or you may have followed a broken link.
            </MudText>

            <div class="action-stack">
                <MudButton Href="/"
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    Size="Size.Large"
                    FullWidth="true"
                    Class="submit-btn"
                    StartIcon="@Icons.Material.Outlined.Home">
                    Go to homepage
                </MudButton>

                @* <MudButton OnClick="GoBack"
                    Variant="Variant.Outlined"
                    Color="Color.Primary"
                    Size="Size.Large"
                    FullWidth="true"
                    Class="submit-btn"
                    StartIcon="@Icons.Material.Outlined.ArrowBack">
                    Go back
                </MudButton> *@
            </div>

            <MudDivider Class="my-8" />

            <MudText Typo="Typo.caption" Class="mud-text-disabled mb-4" Style="display:block;text-align: center;">
                Looking for something specific?
            </MudText>

            <div class="quick-links">
                <MudLink Href="/login"    Class="quick-link">Sign in</MudLink>
                <MudLink Href="/register" Class="quick-link">Register</MudLink>
                <MudLink Href="/#features" Class="quick-link">Features</MudLink>
                <MudLink Href="/#how"     Class="quick-link">How it works</MudLink>
            </div>

        </div>
    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    .auth-shell {
        min-height: calc(100vh - 64px); /* account for MainLayout appbar */
        display: grid;
        grid-template-columns: 1fr;
    }

    /* ── RIGHT PANEL ───────────────────────────────────────────────────── */
    .auth-form-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 48px;
        background: var(--mud-palette-background);
    }

    .auth-form-card {
        width: 100%;
        max-width: 400px;
        animation: card-rise 0.5s cubic-bezier(.4,0,.2,1) 0.1s both;
    }

    /* Giant 404 numeral */
    .error-code {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(5rem, 10vw, 8rem);
        line-height: 1;
        letter-spacing: -0.04em;
        color: transparent;
        text-align: center;
        -webkit-text-stroke: 2px var(--mud-palette-divider);
        user-select: none;
        animation: code-in 0.6s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes code-in {
        from { opacity: 0; transform: translateY(-12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .form-title    { text-align: center; letter-spacing: -0.02em !important; color: var(--mud-palette-text-primary) !important; }
    .form-subtitle { text-align: center; color: var(--mud-palette-text-secondary) !important; line-height: 1.6 !important; }

    .action-stack { display: flex; flex-direction: column; gap: 10px; }

    .submit-btn {
        border-radius: 10px !important;
        height: 48px !important;
        font-size: 14px !important;
        letter-spacing: 0 !important;
    }

    /* Quick links */
    .quick-links {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 8px;
    }

    .quick-link {
        font-size: 13px !important;
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid var(--mud-palette-divider);
        color: var(--mud-palette-text-secondary) !important;
        text-decoration: none !important;
        transition: border-color 0.15s, color 0.15s;
    }

    .quick-link:hover {
        border-color: var(--mud-palette-primary);
        color: var(--mud-palette-primary) !important;
    }

    /* ── RESPONSIVE ────────────────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .auth-shell     { grid-template-columns: 1fr; }
        .auth-panel     { display: none; }
        .auth-form-side { padding: 40px 24px; min-height: 100vh; }
    }
</style>

@code {
    private string _currentPath = "/";

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        _currentPath = uri.PathAndQuery;
    }

