@page "/login"
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using System.ComponentModel.DataAnnotations

<PageTitle>Sign in — VectorFlow</PageTitle>

<div class="auth-shell">

    <!-- LEFT PANEL — decorative -->
    <div class="auth-panel">
        <a href="/" class="panel-brand">VectorFlow</a>

        <div class="panel-body">
            <div class="panel-kicker">Welcome back</div>
            <p class="panel-headline">Pick up right<br />where you left off.</p>

            <!-- Mini activity feed -->
            <div class="activity-feed">
                @foreach (var item in _feed)
                {
                    <div class="feed-row">
                        <div class="feed-avatar" style="background:@item.AvatarBg">@item.Initials</div>
                        <div class="feed-text">
                            <span class="feed-name">@item.Name</span>
                            <span class="feed-action">@item.Action</span>
                            <span class="feed-target">@item.Target</span>
                        </div>
                        <div class="feed-time">@item.Time</div>
                    </div>
                }
            </div>
        </div>

        <div class="panel-footer">
            <span class="panel-stat">7 issues closed this week</span>
            <div class="panel-stat-bar">
                <div class="panel-stat-fill" style="width:72%"></div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL — form -->
    <div class="auth-form-side">
        <div class="auth-form-card">

            <div class="form-header">
                <MudText Typo="Typo.h3" Class="form-title">Sign in</MudText>
                <MudText Typo="Typo.body2" Class="form-subtitle">
                    No account yet?
                    <MudLink Href="/register" Color="Color.Primary" Underline="Underline.Always">Create one free</MudLink>
                </MudText>
            </div>

            <MudForm @ref="_form" @bind-IsValid="_isValid" Class="auth-mud-form">

                <div class="field-group">
                    <label class="field-label">Email</label>
                    <MudTextField @bind-Value="_model.Email"
                                  Placeholder="you@company.com"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Required="true"
                                  RequiredError="Email is required"
                                  Validation="@(new EmailAddressAttribute() { ErrorMessage = "Enter a valid email" })"
                                  Class="auth-field"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Outlined.AlternateEmail"
                                  AdornmentColor="Color.Default" />
                </div>

                <div class="field-group">
                    <div class="field-label-row">
                        <label class="field-label">Password</label>
                        <MudLink Href="/forgot-password" Typo="Typo.caption" Color="Color.Primary">
                            Forgot password?
                        </MudLink>
                    </div>
                    <MudTextField @bind-Value="_model.Password"
                                  Placeholder="••••••••"
                                  InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Required="true"
                                  RequiredError="Password is required"
                                  Class="auth-field"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword ? Icons.Material.Outlined.VisibilityOff : Icons.Material.Outlined.Visibility)"
                                  OnAdornmentClick="() => _showPassword = !_showPassword"
                                  AdornmentColor="Color.Default" />
                </div>

                <MudButton OnClick="HandleLogin"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Disabled="_loading"
                           Class="submit-btn mt-2">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Signing in…</span>
                    }
                    else
                    {
                        <span>Sign in to VectorFlow</span>
                    }
                </MudButton>

            </MudForm>

            <div class="form-divider">
                <span>or continue with</span>
            </div>

            <div class="oauth-row">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                           StartIcon="@Icons.Custom.Brands.GitHub" Class="oauth-btn">
                    GitHub
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                           StartIcon="@Icons.Custom.Brands.Google" Class="oauth-btn">
                    Google
                </MudButton>
            </div>

        </div>

        <MudText Typo="Typo.caption" Class="form-legal">
            By signing in you agree to our
            <MudLink Href="/terms" Color="Color.Default" Underline="Underline.Always" Typo="Typo.caption">Terms</MudLink>
            and
            <MudLink Href="/privacy" Color="Color.Default" Underline="Underline.Always" Typo="Typo.caption">Privacy Policy</MudLink>.
        </MudText>
    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    /* ── SHELL ─────────────────────────────────────────────────────────── */
    .auth-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    /* ── LEFT PANEL ────────────────────────────────────────────────────── */
    .auth-panel {
        background: var(--mud-palette-dark, #0D0D0F);
        color: var(--mud-palette-white);
        display: flex;
        flex-direction: column;
        padding: 40px 48px;
        position: relative;
        overflow: hidden;
    }

    /* Subtle grid texture */
    .auth-panel::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(var(--mud-palette-primary) 1px, transparent 1px),
            linear-gradient(90deg, var(--mud-palette-primary) 1px, transparent 1px);
        background-size: 48px 48px;
        opacity: 0.04;
        pointer-events: none;
    }

    /* Radial glow */
    .auth-panel::after {
        content: '';
        position: absolute;
        top: -80px;
        left: -80px;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, var(--mud-palette-primary) 0%, transparent 65%);
        opacity: 0.08;
        pointer-events: none;
    }

    .panel-brand {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 1.25rem;
        color: var(--mud-palette-white);
        text-decoration: none;
        position: relative;
        z-index: 1;
    }

    .panel-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 1;
    }

    .panel-kicker {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--mud-palette-primary);
        margin-bottom: 16px;
    }

    .panel-headline {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(2rem, 3vw, 3rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--mud-palette-white);
        margin: 0 0 40px;
    }

    /* Activity feed */
    .activity-feed {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .feed-row {
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 10px;
        padding: 10px 14px;
        animation: feed-in 0.4s ease both;
    }

    .feed-row:nth-child(1) { animation-delay: 0.1s; }
    .feed-row:nth-child(2) { animation-delay: 0.2s; }
    .feed-row:nth-child(3) { animation-delay: 0.3s; }

    @@keyframes feed-in {
        from { opacity: 0; transform: translateX(-10px); }
        to   { opacity: 1; transform: translateX(0); }
    }

    .feed-avatar {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 600;
        color: white;
    }

    .feed-text {
        flex: 1;
        font-size: 12px;
        line-height: 1.4;
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        align-items: baseline;
    }

    .feed-name  { font-weight: 600; color: rgba(255,255,255,0.9); }
    .feed-action { color: rgba(255,255,255,0.45); }
    .feed-target {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--mud-palette-primary);
    }

    .feed-time {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
    }

    /* Stat bar */
    .panel-footer {
        position: relative;
        z-index: 1;
    }

    .panel-stat {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: rgba(255,255,255,0.4);
        display: block;
        margin-bottom: 8px;
    }

    .panel-stat-bar {
        height: 3px;
        background: rgba(255,255,255,0.08);
        border-radius: 99px;
        overflow: hidden;
    }

    .panel-stat-fill {
        height: 100%;
        background: var(--mud-palette-primary);
        border-radius: 99px;
        animation: bar-grow 1.2s cubic-bezier(.4,0,.2,1) 0.5s both;
    }

    @@keyframes bar-grow {
        from { width: 0 !important; }
    }

    /* ── RIGHT / FORM SIDE ─────────────────────────────────────────────── */
    .auth-form-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 48px;
        background: var(--mud-palette-background);
        gap: 20px;
    }

    .auth-form-card {
        width: 100%;
        max-width: 400px;
        animation: card-rise 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes card-rise {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .form-header {
        margin-bottom: 32px;
    }

    .form-title {
        letter-spacing: -0.02em !important;
        margin-bottom: 6px !important;
        color: var(--mud-palette-text-primary) !important;
    }

    .form-subtitle {
        color: var(--mud-palette-text-secondary) !important;
    }

    /* Field groups */
    .auth-mud-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .field-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        font-family: 'DM Sans', system-ui, sans-serif;
        letter-spacing: 0.01em;
    }

    .field-label-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    /* Override MudTextField border-radius to match brand */
    .auth-field .mud-input-outlined .mud-notched-outline {
        border-radius: 10px !important;
    }

    .submit-btn {
        border-radius: 10px !important;
        height: 48px !important;
        font-size: 14px !important;
        letter-spacing: 0 !important;
    }

    /* Divider */
    .form-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 24px 0 16px;
        color: var(--mud-palette-text-disabled);
        font-size: 12px;
    }

    .form-divider::before,
    .form-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--mud-palette-divider);
    }

    /* OAuth */
    .oauth-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .oauth-btn {
        border-radius: 10px !important;
        border-color: var(--mud-palette-divider) !important;
        font-size: 13px !important;
    }

    .form-legal {
        color: var(--mud-palette-text-disabled) !important;
        text-align: center;
        max-width: 320px;
    }

    /* ── RESPONSIVE ────────────────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .auth-shell { grid-template-columns: 1fr; }
        .auth-panel { display: none; }
        .auth-form-side { padding: 40px 24px; }
    }
</style>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading;
    private bool _showPassword;

    private readonly LoginRequest _model = new();

    private record FeedItem(string Initials, string AvatarBg, string Name, string Action, string Target, string Time);

    private readonly List<FeedItem> _feed =
    [
        new("BM", "#4339CA", "Ben M.", "moved", "VF-05 to Done", "2m ago"),
        new("JS", "#1A7A52", "Jana S.", "commented on", "VF-08", "11m ago"),
        new("AK", "#92560F", "Alex K.", "created", "VF-12", "34m ago"),
    ];

    private async Task HandleLogin()
    {
        await _form.Validate();
        if (!_isValid) return;

        _loading = true;
        StateHasChanged();

        // TODO: call your auth service / API here
        // e.g. await AuthService.LoginAsync(_model);

        await Task.Delay(1200); // remove — placeholder
        _loading = false;
        Snackbar.Add("Signed in successfully!", Severity.Success);
        Nav.NavigateTo("/dashboard");
    }

    public class LoginRequest
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = string.Empty;
    }
}
