@page "/dashboard"
@layout Features.Layout.MainLayout
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using VectorFlow.Client.Features.Dashboard.Home.Components
@using VectorFlow.Shared.DTOs
@using VectorFlow.Shared.Enums
@* @inject IWorkspaceService WorkspaceService *@
@* @inject IIssueService IssueService *@
@* @inject IAuthService AuthService *@

<PageTitle>Dashboard — VectorFlow</PageTitle>

@if (_loading)
{
   <LoadingSkeletons/>
}
else if (_isFirstTimeUser)
{
   <FirstTimeUserContent  OpenCreateWorkspace="OpenCreateWorkspace" _userInitials="@_userInitials" _userName="@_userName"/>
}
else
{
    <!-- ══════════════════════════════════════════════
         RETURNING USER — has workspaces and issues
    ══════════════════════════════════════════════ -->
    <div class="dash-shell">

        <!-- ── HEADER ──────────────────────────────────────────── -->
        <div class="dash-header">
            <div class="dash-greeting">
                <div class="greeting-avatar">@_userInitials</div>
                <div>
                    <h1 class="greeting-name">@_greeting, @_userName.</h1>
                    <p class="greeting-sub">
                        @_assignedCount issue@(_assignedCount != 1 ? "s" : "") assigned to you
                        @if (_overdueCount > 0)
                        {
                            <span class="overdue-pill">@_overdueCount overdue</span>
                        }
                    </p>
                </div>
            </div>

            <div class="dash-header-actions">
                <MudButton Variant="Variant.Outlined"
                    Color="Color.Primary"
                    StartIcon="@Icons.Material.Outlined.Add"
                    Size="Size.Small"
                    OnClick="OpenCreateWorkspace"
                    Class="header-action-btn">
                    New workspace
                </MudButton>
            </div>
        </div>

        <!-- ── STAT STRIP ──────────────────────────────────────── -->
        <div class="stat-strip">
            <div class="stat-card">
                <div class="stat-value">@_assignedCount</div>
                <div class="stat-label">Assigned to me</div>
                <div class="stat-bar-track">
                    <div class="stat-bar-fill stat-fill-primary" style="width:@(Math.Min((_assignedCount / 10.0) * 100, 100))%"></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-value stat-urgent">@_overdueCount</div>
                <div class="stat-label">Overdue</div>
                <div class="stat-bar-track">
                    <div class="stat-bar-fill stat-fill-error" style="width:@(Math.Min((_overdueCount / 5.0) * 100, 100))%"></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_inProgressCount</div>
                <div class="stat-label">In progress</div>
                <div class="stat-bar-track">
                    <div class="stat-bar-fill stat-fill-info" style="width:@(Math.Min((_inProgressCount / 10.0) * 100, 100))%"></div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-value stat-success">@_workspaceCount</div>
                <div class="stat-label">Workspace@(_workspaceCount != 1 ? "s" : "")</div>
                <div class="stat-bar-track">
                    <div class="stat-bar-fill stat-fill-success" style="width:@(Math.Min((_workspaceCount / 5.0) * 100, 100))%"></div>
                </div>
            </div>
        </div>

        <!-- ── MAIN GRID ───────────────────────────────────────── -->
        <div class="dash-grid">

            <!-- LEFT COL: My issues -->
            <div class="dash-col-main">

                <!-- My issues header -->
                <div class="section-header">
                    <div class="section-title-group">
                        <span class="section-label">My issues</span>
                        @if (_urgentIssues.Any())
                        {
                            <span class="urgent-badge">@_urgentIssues.Count urgent</span>
                        }
                    </div>
                    <div class="section-filters">
                        @foreach (var f in _filters)
                        {
                            <button class="filter-pill @(_activeFilter == f ? "filter-active" : "")"
                                    @onclick="() => SetFilter(f)">
                                @f
                            </button>
                        }
                    </div>
                </div>

                <!-- Issue list -->
                <div class="issue-list">
                    @{
                        var displayed = GetFilteredIssues();
                    }
                    @if (!displayed.Any())
                    {
                        <div class="issue-empty">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size:32px; color:var(--mud-palette-success); opacity:0.6" />
                            <MudText Typo="Typo.body2" Class="mud-text-disabled mt-2">
                                No issues here — you're clear.
                            </MudText>
                        </div>
                    }
                    else
                    {
                        @foreach (var issue in displayed)
                        {
                            <div class="issue-row @(issue.IsOverdue ? "issue-overdue" : "")"
                                 @onclick="() => NavigateToIssue(issue)">
                                <div class="issue-row-left">
                                    <div class="issue-status-dot status-@issue.StatusClass"></div>
                                    <div class="issue-content">
                                        <div class="issue-row-meta">
                                            <span class="issue-key">@issue.Key</span>
                                            <span class="issue-project">@issue.ProjectName</span>
                                            @if (issue.IsOverdue)
                                            {
                                                <span class="issue-overdue-tag">overdue</span>
                                            }
                                        </div>
                                        <div class="issue-row-title">@issue.Title</div>
                                    </div>
                                </div>
                                <div class="issue-row-right">
                                    <span class="issue-pri pri-@issue.PriorityClass">@issue.PriorityLabel</span>
                                    @if (issue.DueDate.HasValue)
                                    {
                                        <span class="issue-due @(issue.IsOverdue ? "due-overdue" : "")">
                                            @issue.DueDate.Value.ToString("MMM d")
                                        </span>
                                    }
                                    <MudIcon Icon="@Icons.Material.Outlined.ChevronRight"
                                             Style="font-size:16px; color:var(--mud-palette-text-disabled)" />
                                </div>
                            </div>
                        }
                    }
                </div>

            </div>

            <!-- RIGHT COL: Workspaces + jump links -->
            <div class="dash-col-side">

                <!-- Workspaces -->
                <div class="side-section">
                    <div class="section-header">
                        <span class="section-label">Workspaces</span>
                        <MudIconButton Icon="@Icons.Material.Outlined.Add"
                            Size="Size.Small"
                            Color="Color.Primary"
                            OnClick="OpenCreateWorkspace"
                            Title="New workspace" />
                    </div>

                    <div class="workspace-list">
                        @foreach (var ws in _workspaces)
                        {
                            <div class="workspace-card" @onclick="() => NavigateToWorkspace(ws)">
                                <div class="ws-icon" style="background:@ws.AvatarColor">
                                    @ws.Initials
                                </div>
                                <div class="ws-info">
                                    <div class="ws-name">@ws.Name</div>
                                    <div class="ws-meta">
                                        @ws.ProjectCount project@(ws.ProjectCount != 1 ? "s" : "")
                                        · @ws.MemberCount member@(ws.MemberCount != 1 ? "s" : "")
                                    </div>
                                </div>
                                <div class="ws-role @ws.RoleCssClass">@ws.RoleLabel</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Recent projects -->
                @if (_recentProjects.Any())
                {
                    <div class="side-section">
                        <div class="section-header">
                            <span class="section-label">Recent projects</span>
                        </div>
                        <div class="project-list">
                            @foreach (var p in _recentProjects)
                            {
                                <div class="project-row" @onclick="() => NavigateToProject(p)">
                                    <div class="project-key-badge">@p.KeyPrefix</div>
                                    <div class="project-info">
                                        <div class="project-name">@p.Name</div>
                                        <div class="project-ws">@p.WorkspaceName</div>
                                    </div>
                                    <div class="project-open-count">
                                        <span>@p.OpenIssueCount</span>
                                        <MudIcon Icon="@Icons.Material.Outlined.BugReport"
                                                 Style="font-size:11px" />
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>

        </div>
    </div>
}

<!-- CREATE WORKSPACE DIALOG -->
<CreateWorkspaceDialog
    @bind-Open="_createWorkspaceOpen"
    @OpenChanged="OnOpenChangeWorkspaceDialog" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    /* ── SHARED ────────────────────────────────────────────────────────── */
    .field-group   { display: flex; flex-direction: column; gap: 6px; }
    .field-label   {
        font-size: 12px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        font-family: 'DM Sans', system-ui, sans-serif;
    }

    .auth-field .mud-input-outlined .mud-notched-outline {
        border-radius: 10px !important;
    }

    /* ── EMPTY STATE ───────────────────────────────────────────────────── */
    .empty-shell {
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 64px 40px;
        background: var(--mud-palette-background);
    }

    .empty-inner {
        width: 100%;
        max-width: 760px;
        display: flex;
        flex-direction: column;
        gap: 48px;
        animation: card-rise 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes card-rise {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .empty-eyebrow {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .user-dot {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--mud-palette-primary);
        color: white;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'DM Mono', monospace;
    }

    .eyebrow-text {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--mud-palette-text-disabled);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .empty-headline {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(2.4rem, 4vw, 3.6rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--mud-palette-text-primary);
        margin: 0 0 16px;
    }

    .empty-sub {
        font-size: 1rem;
        color: var(--mud-palette-text-secondary);
        line-height: 1.7;
        max-width: 540px;
        margin: 0;
    }

    .empty-cta-wrap {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
    }

    .cta-btn {
        border-radius: 10px !important;
        height: 48px !important;
        font-size: 14px !important;
        letter-spacing: 0 !important;
        padding: 0 28px !important;
    }

    
    /* ── RETURNING USER DASHBOARD ──────────────────────────────────────── */
    .dash-shell {
        max-width: 1160px;
        margin: 0 auto;
        padding: 40px 40px 80px;
        display: flex;
        flex-direction: column;
        gap: 32px;
        animation: card-rise 0.4s cubic-bezier(.4,0,.2,1) both;
    }

    /* Header */
    .dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
    }

    .dash-greeting {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .greeting-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--mud-palette-primary);
        color: white;
        font-family: 'DM Mono', monospace;
        font-size: 14px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .greeting-name {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(1.6rem, 2.5vw, 2.2rem);
        letter-spacing: -0.02em;
        color: var(--mud-palette-text-primary);
        margin: 0 0 2px;
        line-height: 1.15;
    }

    .greeting-sub {
        font-size: 13px;
        color: var(--mud-palette-text-secondary);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .overdue-pill {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        background: rgba(220,38,38,0.1);
        color: var(--mud-palette-error);
        border: 1px solid rgba(220,38,38,0.2);
        padding: 2px 8px;
        border-radius: 99px;
    }

    .header-action-btn {
        border-radius: 8px !important;
        white-space: nowrap;
    }

    /* Stat strip */
    .stat-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
    }

    .stat-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        padding: 18px 20px 14px;
        transition: border-color 0.15s;
    }

    .stat-card:hover { border-color: var(--mud-palette-primary); }

    .stat-value {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 2.2rem;
        line-height: 1;
        letter-spacing: -0.02em;
        color: var(--mud-palette-text-primary);
        margin-bottom: 4px;
    }

    .stat-urgent  { color: var(--mud-palette-error); }
    .stat-success { color: var(--mud-palette-success); }

    .stat-label {
        font-size: 12px;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 12px;
        font-weight: 500;
    }

    .stat-bar-track {
        height: 3px;
        background: var(--mud-palette-lines-default);
        border-radius: 99px;
        overflow: hidden;
    }

    .stat-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width 1s cubic-bezier(.4,0,.2,1);
    }

    .stat-fill-primary { background: var(--mud-palette-primary); }
    .stat-fill-error   { background: var(--mud-palette-error); }
    .stat-fill-info    { background: var(--mud-palette-info); }
    .stat-fill-success { background: var(--mud-palette-success); }

    /* Main grid */
    .dash-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 24px;
        align-items: flex-start;
    }

    .dash-col-main,
    .dash-col-side {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* Section headers */
    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
        flex-wrap: wrap;
        gap: 8px;
    }

    .section-title-group {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-label {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--mud-palette-text-disabled);
    }

    .urgent-badge {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        background: rgba(220,38,38,0.1);
        color: var(--mud-palette-error);
        border: 1px solid rgba(220,38,38,0.15);
        padding: 2px 8px;
        border-radius: 99px;
    }

    /* Filter pills */
    .section-filters {
        display: flex;
        gap: 4px;
    }

    .filter-pill {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 99px;
        border: 1px solid var(--mud-palette-divider);
        background: transparent;
        color: var(--mud-palette-text-disabled);
        cursor: pointer;
        transition: all 0.15s;
    }

    .filter-pill:hover {
        border-color: var(--mud-palette-primary);
        color: var(--mud-palette-primary);
    }

    .filter-active {
        background: var(--mud-palette-primary-lighten);
        border-color: var(--mud-palette-primary);
        color: var(--mud-palette-primary);
    }

    /* Issue list */
    .issue-list {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        overflow: hidden;
    }

    .issue-empty {
        padding: 48px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .issue-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        cursor: pointer;
        transition: background 0.12s;
    }

    .issue-row:last-child { border-bottom: none; }
    .issue-row:hover      { background: var(--mud-palette-background-grey); }

    .issue-row-left {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        flex: 1;
        min-width: 0;
    }

    /* Status dot */
    .issue-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 6px;
    }

    .status-backlog    { background: var(--mud-palette-text-disabled); }
    .status-todo       { background: var(--mud-palette-info); }
    .status-inprogress {
        background: var(--mud-palette-primary);
        box-shadow: 0 0 0 2px var(--mud-palette-primary-lighten);
    }
    .status-inreview   { background: var(--mud-palette-warning); }
    .status-done       { background: var(--mud-palette-success); }

    .issue-content { flex: 1; min-width: 0; }

    .issue-row-meta {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 3px;
        flex-wrap: wrap;
    }

    .issue-key {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--mud-palette-primary);
        font-weight: 500;
    }

    .issue-project {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--mud-palette-text-disabled);
    }

    .issue-overdue-tag {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        background: rgba(220,38,38,0.1);
        color: var(--mud-palette-error);
        padding: 1px 5px;
        border-radius: 3px;
    }

    .issue-row-title {
        font-size: 13px;
        font-weight: 500;
        color: var(--mud-palette-text-primary);
        line-height: 1.4;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .issue-row-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    /* Priority chips */
    .issue-pri {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        font-weight: 500;
        padding: 2px 6px;
        border-radius: 3px;
        white-space: nowrap;
    }

    .pri-urgent { background: rgba(220,38,38,0.12); color: var(--mud-palette-error); }
    .pri-high   { background: rgba(217,119,6,0.12); color: var(--mud-palette-warning); }
    .pri-medium { background: rgba(37,99,235,0.1);  color: var(--mud-palette-info); }
    .pri-low    { background: var(--mud-palette-lines-default); color: var(--mud-palette-text-disabled); }

    .issue-due {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--mud-palette-text-disabled);
        white-space: nowrap;
    }

    .due-overdue { color: var(--mud-palette-error) !important; }

    /* Overdue row highlight */
    .issue-overdue { border-left: 2px solid var(--mud-palette-error); }

    /* Side sections */
    .side-section {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        padding: 18px 16px;
    }

    /* Workspace cards */
    .workspace-list { display: flex; flex-direction: column; gap: 8px; }

    .workspace-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid var(--mud-palette-divider);
        cursor: pointer;
        transition: border-color 0.15s, background 0.12s;
        background: var(--mud-palette-background);
    }

    .workspace-card:hover {
        border-color: var(--mud-palette-primary);
        background: var(--mud-palette-primary-lighten);
    }

    .ws-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        color: white;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ws-info { flex: 1; min-width: 0; }

    .ws-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ws-meta {
        font-size: 11px;
        color: var(--mud-palette-text-disabled);
        font-family: 'DM Mono', monospace;
    }

    .ws-role {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        font-weight: 500;
        padding: 2px 7px;
        border-radius: 99px;
        flex-shrink: 0;
    }

    .role-owner  { background: rgba(146,64,14,0.1);  color: var(--mud-palette-warning); border: 1px solid rgba(146,64,14,0.2); }
    .role-admin  { background: var(--mud-palette-primary-lighten); color: var(--mud-palette-primary); border: 1px solid rgba(67,57,202,0.2); }
    .role-member { background: rgba(26,122,82,0.1);  color: var(--mud-palette-success); border: 1px solid rgba(26,122,82,0.2); }

    /* Recent projects */
    .project-list { display: flex; flex-direction: column; gap: 6px; }

    .project-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.12s;
    }

    .project-row:hover { background: var(--mud-palette-background-grey); }

    .project-key-badge {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 4px;
        background: var(--mud-palette-primary-lighten);
        color: var(--mud-palette-primary);
        flex-shrink: 0;
    }

    .project-info { flex: 1; min-width: 0; }

    .project-name {
        font-size: 12px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .project-ws {
        font-size: 11px;
        color: var(--mud-palette-text-disabled);
        font-family: 'DM Mono', monospace;
    }

    .project-open-count {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--mud-palette-text-disabled);
        display: flex;
        align-items: center;
        gap: 3px;
