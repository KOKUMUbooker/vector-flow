        DateTime?     DueDate,
        bool          IsOverdue,
        // Pre-computed CSS tokens
        string StatusClass,
        string PriorityClass,
        string StatusLabel,
        string PriorityLabel
    );

    private sealed record DashWorkspace(
        Guid          Id,
        string        Slug,
        string        Name,
        string        Initials,
        string        AvatarColor,   // deterministic colour from name hash
        WorkspaceRole Role,
        int           ProjectCount,
        int           MemberCount
    )
    {
        public string RoleLabel   => Role.ToString();
        public string RoleCssClass => Role switch
        {
            WorkspaceRole.Owner  => "role-owner",
            WorkspaceRole.Admin  => "role-admin",
            _                   => "role-member"
