@page "/dashboard"
@layout Features.Layout.MainLayout
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using VectorFlow.Client.Features.Dashboard.Home.Components
@using VectorFlow.Client.Services.Interfaces
@using VectorFlow.Shared.DTOs
@using VectorFlow.Shared.Enums
@inject IClientAuthService AuthService
@inject IDashboardService DashboardService

<PageTitle>Dashboard — VectorFlow</PageTitle>

@if (_loading)
{
   <LoadingSkeletons/>
}
else if (_isFirstTimeUser)
{
   <FirstTimeUserContent OpenCreateWorkspace="OpenCreateWorkspace" _userInitials="@_userInitials" _userName="@_userName"/>
}
else
{
    <div class="dash-shell">

        <!-- ── HEADER ──────────────────────────────────────────── -->
        <div class="dash-header">
            <div class="dash-greeting">
                <div class="greeting-avatar">@_userInitials</div>
                <div>
                    <h1 class="greeting-name">@_greeting, @_userName.</h1>
                    <p class="greeting-sub">
                        @_stats.AssignedCount issue@(_stats.AssignedCount != 1 ? "s" : "") assigned to you
                        @if (_stats.OverdueCount > 0)
                        {
                            <span class="overdue-pill">@_stats.OverdueCount overdue</span>
                        }
                    </p>
                </div>
            </div>
            <div class="dash-header-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.Add"
                           Size="Size.Small"
                           OnClick="OpenCreateWorkspace"
                           Class="header-action-btn">
                    New workspace
                </MudButton>
            </div>
        </div>

        <!-- ── STAT STRIP ──────────────────────────────────────── -->
        <div class="stat-strip">
            <div class="stat-card">
                <div class="stat-value">@_stats.AssignedCount</div>
                <div class="stat-label">Assigned to me</div>
            </div>
            <div class="stat-card">
                <div class="stat-value stat-urgent">@_stats.OverdueCount</div>
                <div class="stat-label">Overdue</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@_stats.InProgressCount</div>
                <div class="stat-label">In progress</div>
            </div>
            <div class="stat-card">
                <div class="stat-value stat-success">@_stats.WorkspaceCount</div>
                <div class="stat-label">Workspace@(_stats.WorkspaceCount != 1 ? "s" : "")</div>
            </div>
        </div>

        <!-- ── MAIN GRID ───────────────────────────────────────── -->
        <div class="dash-grid">

            <!-- LEFT COL: My issues -->
            <div class="dash-col-main">

                <div class="section-header">
                    <div class="section-title-group">
                        <span class="section-label">My issues</span>
                        @if (_issues.HighPriority.Any())
                        {
                            <span class="urgent-badge">@_issues.HighPriority.Count urgent</span>
                        }
                    </div>
                    <div class="section-filters">
                        @foreach (var f in _filters)
                        {
                            <button class="filter-pill @(_activeFilter == f.Key ? "filter-active" : "")"
                                    @onclick="() => _activeFilter = f.Key">
                                @f.Label
                            </button>
                        }
                    </div>
                </div>

                <div class="issue-list">
                    @{
                        var displayed = GetFilteredIssues();
                    }
                    @if (!displayed.Any())
                    {
                        <div class="issue-empty">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle"
                                     Style="font-size:32px; color:var(--mud-palette-success); opacity:0.6" />
                            <MudText Typo="Typo.body2" Class="mud-text-disabled mt-2">
                                No issues here — you're clear.
                            </MudText>
                        </div>
                    }
                    else
                    {
                        @foreach (var issue in displayed)
                        {
                            <div class="issue-row @(issue.IsOverdue ? "issue-overdue" : "")"
                                 @onclick="() => NavigateToIssue(issue)">
                                <div class="issue-row-left">
                                    <div class="issue-status-dot status-@StatusCss(issue.Status)"></div>
                                    <div class="issue-content">
                                        <div class="issue-row-meta">
                                            <span class="issue-key">@issue.Key</span>
                                            <span class="issue-project">@issue.ProjectName</span>
                                            @if (issue.IsOverdue)
                                            {
                                                <span class="issue-overdue-tag">overdue</span>
                                            }
                                        </div>
                                        <div class="issue-row-title">@issue.Title</div>
                                    </div>
                                </div>
                                <div class="issue-row-right">
                                    <span class="issue-pri pri-@PriorityCss(issue.Priority)">
                                        @issue.Priority
                                    </span>
                                    @if (issue.DueDate.HasValue)
                                    {
                                        <span class="issue-due @(issue.IsOverdue ? "due-overdue" : "")">
                                            @issue.DueDate.Value.ToString("MMM d")
                                        </span>
                                    }
                                    <MudIcon Icon="@Icons.Material.Outlined.ChevronRight"
                                             Style="font-size:16px; color:var(--mud-palette-text-disabled)" />
                                </div>
                            </div>
                        }
                    }
                </div>

            </div>

            <!-- RIGHT COL: Workspaces + jump links -->
            <div class="dash-col-side">

                <div class="side-section">
                    <div class="section-header">
                        <span class="section-label">Workspaces</span>
                        <MudIconButton Icon="@Icons.Material.Outlined.Add"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="OpenCreateWorkspace"
                                       Title="New workspace" />
                    </div>
                    <div class="workspace-list">
                        @foreach (var ws in _workspaces)
                        {
                            <div class="workspace-card" @onclick="() => OpenWorkspace(ws.Slug, ws.Id)">
                                <div class="ws-icon" style="background:@PickAvatarColor(ws.Id)">
                                    @GetInitials(ws.Name)
                                </div>
                                <div class="ws-info">
                                    <div class="ws-name">@ws.Name</div>
                                    <div class="ws-meta">
                                        @ws.ProjectCount project@(ws.ProjectCount != 1 ? "s" : "")
                                        · @ws.MemberCount member@(ws.MemberCount != 1 ? "s" : "")
                                    </div>
                                </div>
                                <div class="@RoleCss(ws.Role)">@ws.Role</div>
                            </div>
                        }
                    </div>
                </div>

                @if (_recentProjects.Any())
                {
                    <div class="side-section">
                        <div class="section-header">
                            <span class="section-label">Recent projects</span>
                        </div>
                        <div class="project-list">
                            @foreach (var p in _recentProjects)
                            {
                                <div class="project-row"
                                    @onclick="() => OpenProject(p.WorkspaceSlug,p.Id)">
                                     
                                    <div class="project-key-badge">@p.KeyPrefix</div>
                                    <div class="project-info">
                                        <div class="project-name">@p.Name</div>
                                        <div class="project-ws">@p.WorkspaceName</div>
                                    </div>
                                    <div class="project-open-count">
                                        <span>@p.OpenIssueCount</span>
                                        <MudIcon Icon="@Icons.Material.Outlined.BugReport"
                                                 Style="font-size:11px" />
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
}

<CreateWorkspaceDialog
    @bind-Open="_createWorkspaceOpen"
    OnOpenChangeWorkspaceDialog="OnOpenChangeWorkspaceDialog" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    .field-group { display: flex; flex-direction: column; gap: 6px; }
    .field-label { font-size: 12px; font-weight: 600; color: var(--mud-palette-text-primary); font-family: 'DM Sans', system-ui, sans-serif; }
    .auth-field .mud-input-outlined .mud-notched-outline { border-radius: 10px !important; }

    .empty-shell { min-height: calc(100vh - 64px); display: flex; align-items: flex-start; justify-content: center; padding: 64px 40px; background: var(--mud-palette-background); }
    .empty-inner { width: 100%; max-width: 760px; display: flex; flex-direction: column; gap: 48px; animation: card-rise 0.5s cubic-bezier(.4,0,.2,1) both; }

    @@keyframes card-rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    .empty-eyebrow { display: flex; align-items: center; gap: 10px; }
    .user-dot { width: 28px; height: 28px; border-radius: 50%; background: var(--mud-palette-primary); color: white; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; font-family: 'DM Mono', monospace; }
    .eyebrow-text { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--mud-palette-text-disabled); text-transform: uppercase; letter-spacing: 0.08em; }
    .empty-headline { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(2.4rem, 4vw, 3.6rem); line-height: 1.1; letter-spacing: -0.02em; color: var(--mud-palette-text-primary); margin: 0 0 16px; }
    .empty-sub { font-size: 1rem; color: var(--mud-palette-text-secondary); line-height: 1.7; max-width: 540px; margin: 0; }
    .empty-cta-wrap { display: flex; flex-direction: column; align-items: flex-start; gap: 4px; }
    .cta-btn { border-radius: 10px !important; height: 48px !important; font-size: 14px !important; letter-spacing: 0 !important; padding: 0 28px !important; }

    .dash-shell { max-width: 1160px; margin: 0 auto; padding: 40px 40px 80px; display: flex; flex-direction: column; gap: 32px; animation: card-rise 0.4s cubic-bezier(.4,0,.2,1) both; }

    .dash-header { display: flex; align-items: center; justify-content: space-between; gap: 20px; }
    .dash-greeting { display: flex; align-items: center; gap: 14px; }
    .greeting-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--mud-palette-primary); color: white; font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .greeting-name { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(1.6rem, 2.5vw, 2.2rem); letter-spacing: -0.02em; color: var(--mud-palette-text-primary); margin: 0 0 2px; line-height: 1.15; }
    .greeting-sub { font-size: 13px; color: var(--mud-palette-text-secondary); margin: 0; display: flex; align-items: center; gap: 8px; }
    .overdue-pill { font-family: 'DM Mono', monospace; font-size: 10px; font-weight: 500; background: rgba(220,38,38,0.1); color: var(--mud-palette-error); border: 1px solid rgba(220,38,38,0.2); padding: 2px 8px; border-radius: 99px; }
    .header-action-btn { border-radius: 8px !important; white-space: nowrap; }

    .stat-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .stat-card { background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 12px; padding: 18px 20px 14px; transition: border-color 0.15s; }
    .stat-card:hover { border-color: var(--mud-palette-primary); }
    .stat-value { font-family: 'DM Serif Display', Georgia, serif; font-size: 2.2rem; line-height: 1; letter-spacing: -0.02em; color: var(--mud-palette-text-primary); margin-bottom: 4px; }
    .stat-urgent { color: var(--mud-palette-error); }
    .stat-success { color: var(--mud-palette-success); }
    .stat-label { font-size: 12px; color: var(--mud-palette-text-secondary); margin-bottom: 12px; font-weight: 500; }

    .dash-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; align-items: flex-start; }
    .dash-col-main, .dash-col-side { display: flex; flex-direction: column; gap: 24px; }

    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; flex-wrap: wrap; gap: 8px; }
    .section-title-group { display: flex; align-items: center; gap: 10px; }
    .section-label { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mud-palette-text-disabled); }
    .urgent-badge { font-family: 'DM Mono', monospace; font-size: 10px; font-weight: 500; background: rgba(220,38,38,0.1); color: var(--mud-palette-error); border: 1px solid rgba(220,38,38,0.15); padding: 2px 8px; border-radius: 99px; }

    .section-filters { display: flex; gap: 4px; }
    .filter-pill { font-family: 'DM Mono', monospace; font-size: 10px; font-weight: 500; padding: 3px 10px; border-radius: 99px; border: 1px solid var(--mud-palette-divider); background: transparent; color: var(--mud-palette-text-disabled); cursor: pointer; transition: all 0.15s; }
    .filter-pill:hover { border-color: var(--mud-palette-primary); color: var(--mud-palette-primary); }
    .filter-active { background: var(--mud-palette-primary-lighten); border-color: var(--mud-palette-primary); color: var(--mud-palette-primary); }

    .issue-list { background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 12px; overflow: hidden; }
    .issue-empty { padding: 48px 24px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
    .issue-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 16px; border-bottom: 1px solid var(--mud-palette-divider); cursor: pointer; transition: background 0.12s; }
    .issue-row:last-child { border-bottom: none; }
    .issue-row:hover { background: var(--mud-palette-background-grey); }
    .issue-row-left { display: flex; align-items: flex-start; gap: 12px; flex: 1; min-width: 0; }
    .issue-status-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 6px; }
    .status-backlog { background: var(--mud-palette-text-disabled); }
    .status-todo { background: var(--mud-palette-info); }
    .status-inprogress { background: var(--mud-palette-primary); box-shadow: 0 0 0 2px var(--mud-palette-primary-lighten); }
    .status-inreview { background: var(--mud-palette-warning); }
    .status-done { background: var(--mud-palette-success); }
    .issue-content { flex: 1; min-width: 0; }
    .issue-row-meta { display: flex; align-items: center; gap: 6px; margin-bottom: 3px; flex-wrap: wrap; }
    .issue-key { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--mud-palette-primary); font-weight: 500; }
    .issue-project { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--mud-palette-text-disabled); }
    .issue-overdue-tag { font-family: 'DM Mono', monospace; font-size: 9px; background: rgba(220,38,38,0.1); color: var(--mud-palette-error); padding: 1px 5px; border-radius: 3px; }
    .issue-row-title { font-size: 13px; font-weight: 500; color: var(--mud-palette-text-primary); line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .issue-row-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .issue-pri { font-family: 'DM Mono', monospace; font-size: 9px; font-weight: 500; padding: 2px 6px; border-radius: 3px; white-space: nowrap; }
    .pri-urgent { background: rgba(220,38,38,0.12); color: var(--mud-palette-error); }
    .pri-high { background: rgba(217,119,6,0.12); color: var(--mud-palette-warning); }
    .pri-medium { background: rgba(37,99,235,0.1); color: var(--mud-palette-info); }
    .pri-low { background: var(--mud-palette-lines-default); color: var(--mud-palette-text-disabled); }
    .issue-due { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--mud-palette-text-disabled); white-space: nowrap; }
    .due-overdue { color: var(--mud-palette-error) !important; }
    .issue-overdue { border-left: 2px solid var(--mud-palette-error); }

    .side-section { background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 12px; padding: 18px 16px; }
    .workspace-list { display: flex; flex-direction: column; gap: 8px; }
    .workspace-card { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; border: 1px solid var(--mud-palette-divider); cursor: pointer; transition: border-color 0.15s, background 0.12s; background: var(--mud-palette-background); }
    .workspace-card:hover { border-color: var(--mud-palette-primary); background: var(--mud-palette-primary-lighten); }
    .ws-icon { width: 32px; height: 32px; border-radius: 8px; color: white; font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ws-info { flex: 1; min-width: 0; }
    .ws-name { font-size: 13px; font-weight: 600; color: var(--mud-palette-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ws-meta { font-size: 11px; color: var(--mud-palette-text-disabled); font-family: 'DM Mono', monospace; }
    .ws-role { font-family: 'DM Mono', monospace; font-size: 9px; font-weight: 500; padding: 2px 7px; border-radius: 99px; flex-shrink: 0; }
    .role-owner { background: rgba(146,64,14,0.1); color: var(--mud-palette-warning); border: 1px solid rgba(146,64,14,0.2); }
    .role-admin { background: var(--mud-palette-primary-lighten); color: var(--mud-palette-primary); border: 1px solid rgba(67,57,202,0.2); }
    .role-member { background: rgba(26,122,82,0.1); color: var(--mud-palette-success); border: 1px solid rgba(26,122,82,0.2); }

    .project-list { display: flex; flex-direction: column; gap: 6px; }
    .project-row { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; cursor: pointer; transition: background 0.12s; }
    .project-row:hover { background: var(--mud-palette-background-grey); }
    .project-key-badge { font-family: 'DM Mono', monospace; font-size: 9px; font-weight: 600; padding: 2px 6px; border-radius: 4px; background: var(--mud-palette-primary-lighten); color: var(--mud-palette-primary); flex-shrink: 0; }
    .project-info { flex: 1; min-width: 0; }
    .project-name { font-size: 12px; font-weight: 600; color: var(--mud-palette-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .project-ws { font-size: 11px; color: var(--mud-palette-text-disabled); font-family: 'DM Mono', monospace; }
    .project-open-count { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--mud-palette-text-disabled); display: flex; align-items: center; gap: 3px; flex-shrink: 0; }

    @@media (max-width: 960px) {
        .dash-shell { padding: 24px 20px 60px; }
        .dash-grid { grid-template-columns: 1fr; }
        .stat-strip { grid-template-columns: repeat(2, 1fr); }
        .empty-shell { padding: 40px 20px; }
    }

    @@media (max-width: 600px) {
        .stat-strip { grid-template-columns: 1fr 1fr; }
        .dash-header { flex-direction: column; align-items: flex-start; }
    }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    // ── Page state ───────────────────────────────────────────────────────
    private bool _loading        = true;
    private bool _isFirstTimeUser;

    protected string _userName     = "there";
    protected string _userInitials = "?";
    protected string _greeting     = "Good morning";

    // Bound directly from DashboardDto — no client-side computation
    private DashboardStatsDto            _stats          = new();
    private List<DashboardWorkspaceDto>  _workspaces     = [];
    private List<DashboardProjectDto>    _recentProjects = [];
    private DashboardIssuesDto           _issues         = new();

    private bool _createWorkspaceOpen;

    // ── Filter tab model ─────────────────────────────────────────────────
    // Enum key maps 1-to-1 with the server-grouped buckets in DashboardIssuesDto,
    // so switching filter tabs is just picking a different list — no LINQ needed.
    private enum IssueFilter { All, InProgress, Overdue, HighPriority }

    private IssueFilter _activeFilter = IssueFilter.All;

    private static readonly (IssueFilter Key, string Label)[] _filters =
    [
        (IssueFilter.All,          "All"),
        (IssueFilter.InProgress,   "In Progress"),
        (IssueFilter.Overdue,      "Overdue"),
        (IssueFilter.HighPriority, "High priority"),
    ];

    // ── Lifecycle ────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        SetGreeting();
        await LoadDashboard();
    }

    private void SetGreeting()
    {
        var hour = DateTime.Now.Hour;
        _greeting = hour switch
        {
            < 12 => "Good morning",
            < 17 => "Good afternoon",
            _    => "Good evening"
        };
    }

    private async Task LoadDashboard()
    {
        _loading = true;

        try
        {
            // ── Resolve display name from the auth state cascade ──────────
            // This reads the claims that your JWT authentication handler
            // puts into the ClaimsPrincipal — adjust claim names to match
            // whatever your token uses ("name", "displayName", "given_name").
            if (AuthenticationState is not null)
            {
                var authState = await AuthenticationState;
                var user      = authState.User;

                if (user.Identity?.IsAuthenticated == true)
                {
                    var displayName = user.FindFirst("name")?.Value
                                   ?? user.FindFirst("displayName")?.Value
                                   ?? user.Identity.Name
                                   ?? "there";

                    _userName     = FirstName(displayName);
                    _userInitials = GetInitials(displayName);
                }
            }

            // ── Single API call ───────────────────────────────────────────
            // GET /api/dashboard — returns DashboardDto
            var summary = await DashboardService.GetDashboardAsync();

            if (summary is null)
            {
                Snackbar.Add("Could not load dashboard data.", Severity.Error);
                return;
            }

            _isFirstTimeUser = summary.IsFirstTimeUser;

            if (!_isFirstTimeUser)
            {
                _stats          = summary.Stats;
                _workspaces     = summary.Workspaces;
                _recentProjects = summary.RecentProjects;
                _issues         = summary.Issues;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Filtering ─────────────────────────────────────────────────────────
    // Server pre-grouped the buckets — just pick the right list.
    private List<DashboardIssueDto> GetFilteredIssues() => _activeFilter switch
    {
        IssueFilter.InProgress   => _issues.InProgress,
        IssueFilter.Overdue      => _issues.Overdue,
        IssueFilter.HighPriority => _issues.HighPriority,
        _                        => _issues.All,
    };

    // ── Navigation ────────────────────────────────────────────────────────
    private void NavigateToIssue(DashboardIssueDto issue) =>
        Nav.NavigateTo($"/w/{issue.WorkspaceSlug}/projects/{issue.ProjectId}/issues/{issue.Id}");

    // ── Dialog ────────────────────────────────────────────────────────────
    private void OpenCreateWorkspace() => _createWorkspaceOpen = true;

    protected void OnOpenChangeWorkspaceDialog(bool show) =>
        _createWorkspaceOpen = show;

    // ── CSS helpers ───────────────────────────────────────────────────────
    private static string StatusCss(IssueStatus s) => s switch
    {
        IssueStatus.InProgress => "inprogress",
        IssueStatus.InReview   => "inreview",
        _                      => s.ToString().ToLower()
    };

    private static string PriorityCss(IssuePriority p) => p switch
    {
        IssuePriority.Urgent => "urgent",
        IssuePriority.High   => "high",
        IssuePriority.Medium => "medium",
        IssuePriority.Low    => "low",
        _                    => "low"
    };

    private static string RoleCss(WorkspaceRole r) => r switch
    {
        WorkspaceRole.Owner => "ws-role role-owner",
        WorkspaceRole.Admin => "ws-role role-admin",
        _                   => "ws-role role-member"
    };

    // ── Display helpers ───────────────────────────────────────────────────
    private void OpenWorkspace(string slug, Guid id)
    {
        Nav.NavigateTo($"/w/{slug}?id={id}");
    }

    private void OpenProject(string workspaceSlug, Guid projectId )
    {
        Nav.NavigateTo($"/w/{workspaceSlug}/projects/{projectId}");
    }

    private static string FirstName(string displayName)
    {
        var first = displayName.Trim()
                               .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                               .FirstOrDefault();
        return first ?? displayName;
    }

    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    private static readonly string[] AvatarPalette =
    [
        "#4339CA", "#1A7A52", "#92560F", "#2563EB",
        "#7C3AED", "#0E7490", "#B45309", "#DC2626"
    ];

    private static string PickAvatarColor(Guid id) =>
        AvatarPalette[Math.Abs(id.GetHashCode()) % AvatarPalette.Length];
}
