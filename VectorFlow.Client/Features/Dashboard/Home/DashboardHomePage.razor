    // ── DTO → View-model mappers ─────────────────────────────────────────

    private static DashWorkspace MapWorkspace(WorkspaceDto dto) => new(
        Id           : dto.Id,
        Slug         : dto.Slug,
        Name         : dto.Name,
        Initials     : GetInitials(dto.Name),
        AvatarColor  : PickAvatarColor(dto.Id),
        Role         : dto.CurrentUserRole,
        ProjectCount : dto.ProjectCount,
        MemberCount  : dto.MemberCount
    );

    private static DashProject MapProject(ProjectDto dto, WorkspaceDto ws) => new(
        Id             : dto.Id,
        WorkspaceId    : ws.Id,
        WorkspaceSlug  : ws.Slug,
        WorkspaceName  : ws.Name,
        KeyPrefix      : dto.KeyPrefix,
        Name           : dto.Name,
        OpenIssueCount : dto.IssueCount   // server returns total open issues in IssueCount
    );

    /// <summary>
    /// Maps an <see cref="IssueDto"/> (received from GET /api/projects/{id}/issues)
    /// to the flat dashboard view-model.
    /// </summary>
    private static DashIssue MapIssue(IssueDto dto, string projectName, string workspaceSlug)
    {
        var isOverdue = dto.DueDate.HasValue && dto.DueDate.Value.Date < DateTime.Today
                        && dto.Status != IssueStatus.Done;
        return new DashIssue(
            Id                  : dto.Id,
            ProjectId           : dto.ProjectId,
            Key                 : dto.Key,
            Title               : dto.Title,
            ProjectName         : projectName,
            WorkspaceSlug       : workspaceSlug,
            Status              : dto.Status,
            Priority            : dto.Priority,
            Type                : dto.Type,
            AssigneeDisplayName : dto.AssigneeDisplayName,
            DueDate             : dto.DueDate,
            IsOverdue           : isOverdue,
            StatusClass         : StatusCssClass(dto.Status),
            PriorityClass       : PriorityCssClass(dto.Priority),
            StatusLabel         : StatusLabel(dto.Status),
            PriorityLabel       : dto.Priority.ToString()
        );
    }

    // ── CSS / display helpers for enums ─────────────────────────────────

    private static string StatusCssClass(IssueStatus s) => s switch
    {
        IssueStatus.Backlog    => "backlog",
        IssueStatus.Todo       => "todo",
        IssueStatus.InProgress => "inprogress",
        IssueStatus.InReview   => "inreview",
        IssueStatus.Done       => "done",
        _                      => "backlog"
    };

    private static string StatusLabel(IssueStatus s) => s switch
    {
        IssueStatus.InProgress => "In Progress",
        IssueStatus.InReview   => "In Review",
        _                      => s.ToString()
    };

    private static string PriorityCssClass(IssuePriority p) => p switch
    {
        IssuePriority.Urgent => "urgent",
        IssuePriority.High   => "high",
        IssuePriority.Medium => "medium",
        IssuePriority.Low    => "low",
        _                    => "low"
    };

    /// <summary>Lower = shown first in the list.</summary>
    private static int PriorityOrder(IssuePriority p) => p switch
    {
        IssuePriority.Urgent => 0,
        IssuePriority.High   => 1,
        IssuePriority.Medium => 2,
        IssuePriority.Low    => 3,
        _                    => 4
    };

    // ── Filtering ────────────────────────────────────────────────────────
    private void SetFilter(string filter) => _activeFilter = filter;

    private List<DashIssue> GetFilteredIssues() => _activeFilter switch
    {
        "In Progress"   => _myIssues.Where(i => i.Status == IssueStatus.InProgress).ToList(),
        "Overdue"       => _myIssues.Where(i => i.IsOverdue).ToList(),
        "High priority" => _myIssues.Where(i => i.Priority is IssuePriority.Urgent or IssuePriority.High).ToList(),
        _               => _myIssues
    };

    // ── Navigation ───────────────────────────────────────────────────────
    private void NavigateToIssue(DashIssue issue) =>
        Nav.NavigateTo($"/w/{issue.WorkspaceSlug}/projects/{issue.ProjectId}/issues/{issue.Id}");

    private void NavigateToWorkspace(DashWorkspace ws) =>
        Nav.NavigateTo($"/w/{ws.Slug}");

    private void NavigateToProject(DashProject p) =>
        Nav.NavigateTo($"/w/{p.WorkspaceSlug}/projects/{p.Id}");

    // ── Workspace creation ────────────────────────────────────────────────
    private void OpenCreateWorkspace() => _createWorkspaceOpen = true;
    protected void OnOpenChangeWorkspaceDialog (bool show)
    {
        _createWorkspaceOpen = show;    
    }

    private void OnCompleteWorkspaceCreation(string workspaceSlugPreview)
    {
        _createWorkspaceOpen = false;
        Nav.NavigateTo($"/w/{workspaceSlugPreview}");
    }

    // ── Static helpers ────────────────────────────────────────────────────

    private static string FirstName(string displayName)
    {
        var first = displayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        return first ?? displayName;
    }

    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    /// <summary>
    /// Deterministic colour from a workspace GUID so the avatar colour
    /// is stable across sessions without storing it server-side.
    /// </summary>
    private static readonly string[] AvatarPalette =
    [
        "#4339CA", "#1A7A52", "#92560F", "#2563EB",
        "#7C3AED", "#0E7490", "#B45309", "#DC2626"
    ];

    private static string PickAvatarColor(Guid id)
    {
        var idx = Math.Abs(id.GetHashCode()) % AvatarPalette.Length;
        return AvatarPalette[idx];
    }
