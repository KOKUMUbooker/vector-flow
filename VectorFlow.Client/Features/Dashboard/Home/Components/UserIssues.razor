@* @inject NavigationManager Nav

<div class="dash-col-main">
    <!-- My issues header -->
    <div class="section-header">
        <div class="section-title-group">
            <span class="section-label">My issues</span>
            @if (_urgentIssues.Any())
            {
                <span class="urgent-badge">@_urgentIssues.Count urgent</span>
            }
        </div>
        <div class="section-filters">
            @foreach (var f in _filters)
            {
                <button class="filter-pill @(_activeFilter == f ? "filter-active" : "")"
                        @onclick="() => SetFilter(f)">
                    @f
                </button>
            }
        </div>
    </div>

    <!-- Issue list -->
    <div class="issue-list">
        @{
            var displayed = GetFilteredIssues();
        }
        @if (!displayed.Any())
        {
            <div class="issue-empty">
                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Style="font-size:32px; color:var(--mud-palette-success); opacity:0.6" />
                <MudText Typo="Typo.body2" Class="mud-text-disabled mt-2">
                    No issues here — you're clear.
                </MudText>
            </div>
        }
        else
        {
            @foreach (var issue in displayed)
            {
                <div class="issue-row @(issue.IsOverdue ? "issue-overdue" : "")"
                     @onclick="() => NavigateToIssue(issue)">
                    <div class="issue-row-left">
                        <div class="issue-status-dot status-@issue.StatusClass"></div>
                        <div class="issue-content">
                            <div class="issue-row-meta">
                                <span class="issue-key">@issue.Key</span>
                                <span class="issue-project">@issue.ProjectName</span>
                                @if (issue.IsOverdue)
                                {
                                    <span class="issue-overdue-tag">overdue</span>
                                }
                            </div>
                            <div class="issue-row-title">@issue.Title</div>
                        </div>
                    </div>
                    <div class="issue-row-right">
                        <span class="issue-pri pri-@issue.PriorityClass">@issue.PriorityLabel</span>
                        @if (issue.DueDate.HasValue)
                        {
                            <span class="issue-due @(issue.IsOverdue ? "due-overdue" : "")">
                                @issue.DueDate.Value.ToString("MMM d")
                            </span>
                        }
                        <MudIcon Icon="@Icons.Material.Outlined.ChevronRight"
                                 Style="font-size:16px; color:var(--mud-palette-text-disabled)" />
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    
    /* Issue list */
    .issue-list {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        overflow: hidden;
    }

    .issue-empty {
        padding: 48px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .issue-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        cursor: pointer;
        transition: background 0.12s;
    }

    .issue-row:last-child { border-bottom: none; }
    .issue-row:hover      { background: var(--mud-palette-background-grey); }

    .issue-row-left {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        flex: 1;
        min-width: 0;
    }

    /* Status dot */
    .issue-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 6px;
    }

    .status-backlog    { background: var(--mud-palette-text-disabled); }
    .status-todo       { background: var(--mud-palette-info); }
    .status-inprogress {
        background: var(--mud-palette-primary);
        box-shadow: 0 0 0 2px var(--mud-palette-primary-lighten);
    }
    .status-inreview   { background: var(--mud-palette-warning); }
    .status-done       { background: var(--mud-palette-success); }

    .issue-content { flex: 1; min-width: 0; }

    .issue-row-meta {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 3px;
        flex-wrap: wrap;
    }

    .issue-key {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--mud-palette-primary);
        font-weight: 500;
    }

    .issue-project {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--mud-palette-text-disabled);
    }

    .issue-overdue-tag {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        background: rgba(220,38,38,0.1);
        color: var(--mud-palette-error);
        padding: 1px 5px;
        border-radius: 3px;
    }

    .issue-row-title {
        font-size: 13px;
        font-weight: 500;
        color: var(--mud-palette-text-primary);
        line-height: 1.4;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .issue-row-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    /* Priority chips */
    .issue-pri {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        font-weight: 500;
        padding: 2px 6px;
        border-radius: 3px;
        white-space: nowrap;
    }

    .pri-urgent { background: rgba(220,38,38,0.12); color: var(--mud-palette-error); }
    .pri-high   { background: rgba(217,119,6,0.12); color: var(--mud-palette-warning); }
    .pri-medium { background: rgba(37,99,235,0.1);  color: var(--mud-palette-info); }
    .pri-low    { background: var(--mud-palette-lines-default); color: var(--mud-palette-text-disabled); }

    .issue-due {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        color: var(--mud-palette-text-disabled);
        white-space: nowrap;
    }

    .due-overdue { color: var(--mud-palette-error) !important; }

    /* Overdue row highlight */
    .issue-overdue { border-left: 2px solid var(--mud-palette-error); }
</style>

@code {
    private sealed record DashIssue(
        Guid          Id,
        Guid          ProjectId,
        string        Key,
        string        Title,
        string        ProjectName,
        string        WorkspaceSlug,
        IssueStatus   Status,
        IssuePriority Priority,
        IssueType     Type,
        string?       AssigneeDisplayName,
        DateTime?     DueDate,
        bool          IsOverdue,
        // Pre-computed CSS tokens
        string StatusClass,
        string PriorityClass,
        string StatusLabel,
        string PriorityLabel
    );
    private void NavigateToIssue(DashIssue issue) =>
        Nav.NavigateTo($"/w/{issue.WorkspaceSlug}/projects/{issue.ProjectId}/issues/{issue.Id}");
} *@
