@page "/invitations"
@layout Features.Layout.MainLayout
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using VectorFlow.Shared.DTOs
@using VectorFlow.Shared.Enums
@using VectorFlow.Client.Services.Interfaces
@inject IInvitationService InvitationService

<PageTitle>Invitations — VectorFlow</PageTitle>

<div class="page-shell">

    <!-- ── PAGE HEADER ────────────────────────────────────────────────── -->
    <div class="page-header">
        <div>
            <h1 class="page-title">Invitations</h1>
            <p class="page-sub">Workspace invitations sent to your email address.</p>
        </div>
        @if (_pendingCount > 0)
        {
            <div class="pending-pill">
                <div class="pending-pulse"></div>
                @_pendingCount pending
            </div>
        }
    </div>

    @if (_loading)
    {
        <div class="inv-list">
            @for (int i = 0; i < 3; i++)
            {
                <div class="skel skel-row"></div>
            }
        </div>
    }
    else if (!_invitations.Any())
    {
        <div class="empty-state">
            <div class="empty-icon-ring">
                <MudIcon Icon="@Icons.Material.Outlined.MarkEmailRead" Class="empty-icon" />
            </div>
            <MudText Typo="Typo.h5" Class="empty-title mt-6 mb-2">No invitations</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary empty-body mb-8">
                When someone invites you to a workspace you'll see it here.
                In the meantime, you can create your own workspace.
            </MudText>
            <MudButton Href="/workspaces"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.ArrowRight">
                Go to my workspaces
            </MudButton>
        </div>
    }
    else
    {
        <!-- ── PENDING SECTION ─────────────────────────────────────────── -->
        @if (_pending.Any())
        {
            <div class="inv-section">
                <div class="section-header">
                    <span class="section-label">Pending</span>
                    <span class="section-count">@_pending.Count</span>
                </div>

                <div class="inv-list">
                    @foreach (var (inv, idx) in _pending.Select((i, n) => (i, n)))
                    {
                        <div class="inv-card inv-card-pending"
                             style="animation-delay:@(idx * 0.07)s">
                            <div class="inv-left">
                                <div class="ws-avatar-ring">
                                    <div class="ws-avatar-inner">
                                        @GetInitials(inv.WorkspaceName)
                                    </div>
                                </div>
                                <div class="inv-info">
                                    <div class="inv-workspace">@inv.WorkspaceName</div>
                                    <div class="inv-meta">
                                        Invited by
                                        <strong>@inv.InvitedByDisplayName</strong>
                                        · to
                                        <span class="inv-email-pill">@inv.InvitedEmail</span>
                                    </div>
                                    <div class="inv-expiry @(IsExpiringSoon(inv) ? "expiry-warn" : "")">
                                        <MudIcon Icon="@Icons.Material.Outlined.Timer"
                                                 Style="font-size:12px" />
                                        Expires @inv.ExpiresAt.ToString("MMM d, yyyy")
                                        @if (IsExpiringSoon(inv))
                                        {
                                            <span class="expiry-tag">soon</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="inv-actions">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="() => HandleAccept(inv)"
                                           Disabled="@(_actingOn == inv.Id)"
                                           Class="inv-btn">
                                    @if (_actingOn == inv.Id && _actingAccept)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                        <span>Joining…</span>
                                    }
                                    else
                                    {
                                        <span>Accept</span>
                                    }
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           OnClick="() => HandleDecline(inv)"
                                           Disabled="@(_actingOn == inv.Id)"
                                           Class="inv-btn">
                                    @if (_actingOn == inv.Id && !_actingAccept)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                        <span>Declining…</span>
                                    }
                                    else
                                    {
                                        <span>Decline</span>
                                    }
                                </MudButton>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ── HISTORY SECTION ────────────────────────────────────────── -->
        @if (_history.Any())
        {
            <div class="inv-section">
                <div class="section-header">
                    <span class="section-label">History</span>
                    <span class="section-count">@_history.Count</span>
                </div>

                <div class="inv-list">
                    @foreach (var (inv, idx) in _history.Select((i, n) => (i, n)))
                    {
                        <div class="inv-card inv-card-history"
                             style="animation-delay:@((_pending.Count + idx) * 0.06)s">
                            <div class="inv-left">
                                <div class="ws-avatar-ring ws-avatar-muted">
                                    <div class="ws-avatar-inner ws-avatar-inner-muted">
                                        @GetInitials(inv.WorkspaceName)
                                    </div>
                                </div>
                                <div class="inv-info">
                                    <div class="inv-workspace inv-workspace-muted">@inv.WorkspaceName</div>
                                    <div class="inv-meta">
                                        Invited by <strong>@inv.InvitedByDisplayName</strong>
                                        · @inv.CreatedAt.ToString("MMM d, yyyy")
                                    </div>
                                </div>
                            </div>

                            <div class="inv-status-wrap">
                                <div class="status-badge status-@inv.Status.ToString().ToLower()">
                                    @StatusIcon(inv.Status) @inv.Status
                                </div>

                                @if (inv.Status == InvitationStatus.Accepted)
                                {
                                    <MudButton Href="@($"/w/{inv.WorkspaceSlug}")"
                                        Variant="Variant.Text"
                                        Color="Color.Primary"
                                        Size="Size.Small"
                                        EndIcon="@Icons.Material.Outlined.ArrowForward"
                                        Class="open-ws-btn">
                                        Open
                                    </MudButton>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    /* ── SHELL ─────────────────────────────────────────────────────────── */
    .page-shell {
        max-width: 760px;
        margin: 0 auto;
        padding: 40px 40px 80px;
        display: flex;
        flex-direction: column;
        gap: 36px;
        animation: page-in 0.4s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes page-in {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── HEADER ────────────────────────────────────────────────────────── */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

    .page-title {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        letter-spacing: -0.02em;
        color: var(--mud-palette-text-primary);
        margin: 0 0 6px;
        line-height: 1.15;
    }

    .page-sub {
        font-size: 14px;
        color: var(--mud-palette-text-secondary);
        margin: 0;
    }

    /* Pending badge in header */
    .pending-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        font-weight: 500;
        color: var(--mud-palette-primary);
        background: var(--mud-palette-primary-lighten);
        border: 1px solid rgba(67,57,202,0.2);
        padding: 6px 14px;
        border-radius: 99px;
        white-space: nowrap;
        flex-shrink: 0;
        align-self: center;
    }

    .pending-pulse {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--mud-palette-primary);
        animation: vf-pulse 2s infinite;
    }

    @@keyframes vf-pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* ── SKELETON ──────────────────────────────────────────────────────── */
    .skel {
        border-radius: 12px;
        background: var(--mud-palette-lines-default);
        animation: skel-pulse 1.6s ease-in-out infinite;
    }

    @@keyframes skel-pulse { 0%,100%{opacity:.4} 50%{opacity:.8} }

    .skel-row { height: 88px; }

    /* ── EMPTY STATE ───────────────────────────────────────────────────── */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 64px 24px;
    }

    .empty-icon-ring {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: var(--mud-palette-primary-lighten);
        border: 2px solid var(--mud-palette-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        animation: ring-breathe 3s ease-in-out infinite;
    }

    @@keyframes ring-breathe {
        0%,100% { box-shadow: 0 0 0 0 rgba(67,57,202,0.15); }
        50%      { box-shadow: 0 0 0 12px rgba(67,57,202,0); }
    }

    .empty-icon  { color: var(--mud-palette-primary) !important; font-size: 32px !important; }
    .empty-title { font-family: 'DM Serif Display', Georgia, serif; letter-spacing: -0.02em; color: var(--mud-palette-text-primary); }
    .empty-body  { max-width: 380px; line-height: 1.7; }

    /* ── SECTIONS ──────────────────────────────────────────────────────── */
    .inv-section {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .section-label {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--mud-palette-text-disabled);
    }

    .section-count {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        background: var(--mud-palette-lines-default);
        color: var(--mud-palette-text-secondary);
        padding: 1px 7px;
        border-radius: 99px;
    }

    /* ── INVITATION LIST ───────────────────────────────────────────────── */
    .inv-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    /* ── INVITATION CARD ───────────────────────────────────────────────── */
    .inv-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        animation: card-in 0.35s cubic-bezier(.4,0,.2,1) both;
        transition: border-color 0.15s;
    }

    @@keyframes card-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Pending cards get a left accent and hover state */
    .inv-card-pending {
        border-left: 3px solid var(--mud-palette-primary);
    }

    .inv-card-pending:hover {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 4px 16px rgba(67,57,202,0.08);
    }

    /* History cards are visually quieter */
    .inv-card-history { opacity: 0.85; }
    .inv-card-history:hover { opacity: 1; }

    /* ── CARD LEFT ─────────────────────────────────────────────────────── */
    .inv-left {
        display: flex;
        align-items: center;
        gap: 14px;
        flex: 1;
        min-width: 0;
    }

    /* Avatar with pulsing ring on pending */
    .ws-avatar-ring {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 2px solid var(--mud-palette-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 0 0 4px var(--mud-palette-primary-lighten);
        animation: ring-breathe 3s ease-in-out infinite;
    }

    .ws-avatar-muted {
        border-color: var(--mud-palette-divider);
        box-shadow: none;
        animation: none;
    }

    .ws-avatar-inner {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--mud-palette-primary);
        color: white;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ws-avatar-inner-muted {
        background: var(--mud-palette-background-grey);
        color: var(--mud-palette-text-disabled);
    }

    /* Info block */
    .inv-info { flex: 1; min-width: 0; }

    .inv-workspace {
        font-size: 15px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        margin-bottom: 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .inv-workspace-muted { color: var(--mud-palette-text-secondary); }

    .inv-meta {
        font-size: 12px;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .inv-email-pill {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        background: var(--mud-palette-background-grey);
        border: 1px solid var(--mud-palette-divider);
        padding: 1px 6px;
        border-radius: 4px;
        color: var(--mud-palette-text-secondary);
    }

    /* Expiry line */
    .inv-expiry {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--mud-palette-text-disabled);
    }

    .expiry-warn {
        color: var(--mud-palette-warning) !important;
    }

    .expiry-tag {
        font-size: 9px;
        font-weight: 600;
        background: rgba(217,119,6,0.12);
        color: var(--mud-palette-warning);
        border: 1px solid rgba(217,119,6,0.2);
        padding: 1px 5px;
        border-radius: 99px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* ── ACTIONS ───────────────────────────────────────────────────────── */
    .inv-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .inv-btn { border-radius: 8px !important; }

    /* ── STATUS BADGE (history) ────────────────────────────────────────── */
    .inv-status-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .status-badge {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 99px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

    .status-pending  { background: var(--mud-palette-primary-lighten); color: var(--mud-palette-primary);  border: 1px solid rgba(67,57,202,0.2); }
    .status-accepted { background: rgba(26,122,82,0.1);  color: var(--mud-palette-success); border: 1px solid rgba(26,122,82,0.2); }
    .status-declined { background: var(--mud-palette-background-grey); color: var(--mud-palette-text-disabled); border: 1px solid var(--mud-palette-divider); }
    .status-expired  { background: rgba(220,38,38,0.08); color: var(--mud-palette-error);   border: 1px solid rgba(220,38,38,0.15); }

    .open-ws-btn { border-radius: 8px !important; }

    /* ── RESPONSIVE ────────────────────────────────────────────────────── */
    @@media (max-width: 640px) {
        .page-shell { padding: 24px 16px 60px; }
        .inv-card   { flex-direction: column; align-items: flex-start; }
        .inv-actions { width: 100%; }
        .inv-btn    { flex: 1; }
        .inv-status-wrap { width: 100%; justify-content: space-between; }
    }
</style>

@code {
    private bool _loading = true;
    private List<InvitationDto> _invitations = [];

    private Guid? _actingOn;
    private bool  _actingAccept;

    // Derived lists
    private List<InvitationDto> _pending =>
        _invitations.Where(i => i.Status == InvitationStatus.Pending).ToList();

    private List<InvitationDto> _history =>
        _invitations.Where(i => i.Status != InvitationStatus.Pending)
                    .OrderByDescending(i => i.CreatedAt)
                    .ToList();

    private int _pendingCount => _pending.Count;

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;    
            var result = await InvitationService.GetMyInvitations();
            if (result.Succeeded)
            {
                _invitations = result.Data!;
                return;
            }

            Snackbar.Add(result.Error ?? "Failed to fetch invitaions",Severity.Error);
        } 
        finally
        {
            _loading = false;   
        }
    }

    // ── Accept ─────────────────────────────────────────────────────────
    private async Task HandleAccept(InvitationDto inv)
    {
        try
        {
            _actingOn     = inv.Id;
            _actingAccept = true;

            var result = await InvitationService.AcceptInvitationAsync(inv.Token);
            if (result.Succeeded)
            {
                var idx = _invitations.IndexOf(inv);
                if (idx >= 0) _invitations[idx].Status = InvitationStatus.Accepted;
                Snackbar.Add($"You've joined \"{inv.WorkspaceName}\"!", Severity.Success);
                Nav.NavigateTo($"/w/{inv.WorkspaceSlug}");
                return;
            }

            Snackbar.Add(result.Error ?? "Failed to accept invitation", Severity.Error);
        }
        finally
        {
           _actingOn = null;
        }
    }

    // ── Decline ────────────────────────────────────────────────────────
    private async Task HandleDecline(InvitationDto inv)
    {
        try
        {
            _actingOn     = inv.Id;
            _actingAccept = false;

            var result = await InvitationService.DeclineInvitationAsync(inv.Token);
            if (result.Succeeded)
            {
                var idx = _invitations.IndexOf(inv);
                if (idx >= 0) _invitations[idx].Status = InvitationStatus.Declined;
                Snackbar.Add($"Invitation to \"{inv.WorkspaceName}\" declined.", Severity.Info);
                return;
            }

             Snackbar.Add(result.Error ?? "Failed to decline invitation", Severity.Error);
        } 
        finally
        {
            _actingOn = null; 
        }
    }

    // ── Helpers ────────────────────────────────────────────────────────
    private static bool IsExpiringSoon(InvitationDto inv) =>
        inv.ExpiresAt - DateTime.UtcNow < TimeSpan.FromDays(3);

    private static string StatusIcon(InvitationStatus status) => status switch
    {
        InvitationStatus.Accepted => "✓",
        InvitationStatus.Declined => "✕",
        InvitationStatus.Expired  => "⏱",
        _                         => "·"
    };

    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }
}
