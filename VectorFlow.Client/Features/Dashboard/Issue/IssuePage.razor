    .pri-none   { background: var(--mud-palette-text-disabled); }
    .pri-low    { background: var(--mud-palette-success); }
    .pri-medium { background: var(--mud-palette-info); }
    .pri-high   { background: var(--mud-palette-warning); }
    .pri-urgent { background: var(--mud-palette-error); }

    /* Assignee avatar */
    .assignee-avatar-sm {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--mud-palette-primary);
        color: white;
        font-family: 'DM Mono', monospace;
