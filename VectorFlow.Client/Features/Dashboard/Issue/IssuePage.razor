@page "/w/{Slug}/projects/{ProjectId:guid}/issues/{IssueId:guid}"
@layout Features.Layout.MainLayout
@using VectorFlow.Shared.DTOs
@using VectorFlow.Shared.Enums
@using VectorFlow.Client.Services
@using VectorFlow.Client.Services.Interfaces
@using System.Security.Claims;
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IClientIssueService IssueService
@inject IDashboardService DashboardService
@inject IClientCommentService CommentService
@* @inject IWorkspaceService WorkspaceService *@

<PageTitle>@(_issue?.Key ?? "Issue") — VectorFlow</PageTitle>

@if (_loading)
{
    <div class="issue-loading">
        <div class="skel skel-title"></div>
        <div class="issue-layout">
            <div class="skel skel-main"></div>
            <div class="skel skel-sidebar"></div>
        </div>
    </div>
}
else if (_issue is null)
{
    <div class="issue-not-found">
        <MudText Typo="Typo.h4" Class="mud-text-secondary">Issue not found</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-disabled mt-2 mb-6">
            This issue may have been deleted or you don't have access.
        </MudText>
        <MudButton Href="@($"/w/{Slug}")" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.ArrowBack">
            Back to workspace
        </MudButton>
    </div>
}
else
{
    <div class="issue-shell" @key="_issue.Id">

        <!-- ── BREADCRUMB ─────────────────────────────────────────────── -->
        <div class="issue-breadcrumb">
            <MudLink Href="@($"/w/{Slug}")" Class="bc-link">@_workspaceName</MudLink>
            <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Class="bc-sep" />
            <MudLink Href="@($"/w/{Slug}/projects/{ProjectId}")" Class="bc-link">@_projectName</MudLink>
            <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Class="bc-sep" />
            <span class="bc-current">@_issue.Key</span>
        </div>

        <!-- ── TWO-COLUMN LAYOUT ──────────────────────────────────────── -->
        <div class="issue-layout">

            <!-- ── LEFT: Main content ─────────────────────────────────── -->
            <div class="issue-main">

                <!-- Title -->
                @if (_editingTitle)
                {
                    <div class="title-edit-wrap">
                        <MudTextField @bind-Value="_titleDraft"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="title-field"
                                      Immediate="true" />
                        <div class="title-edit-actions">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="SaveTitle" Disabled="_savingTitle">
                                @(_savingTitle ? "Saving…" : "Save")
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                       OnClick="() => _editingTitle = false">
                                Cancel
                            </MudButton>
                        </div>
                    </div>
                }
                else
                {
                    <div class="issue-title-wrap" @onclick="StartEditTitle">
                        <h1 class="issue-title">@_issue.Title</h1>
                        <MudIcon Icon="@Icons.Material.Outlined.Edit" Class="title-edit-icon" />
                    </div>
                }

                <!-- Type + status row -->
                <div class="issue-tags-row">
                    <div class="issue-type-badge type-@_issue.Type.ToString().ToLower()">
                        <MudIcon Icon="@TypeIcon(_issue.Type)" Style="font-size:12px" />
                        @_issue.Type
                    </div>
                    <MudMenu Class="status-menu" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                        <ActivatorContent>
                            <div  class="status-chip status-@StatusCss(_issue.Status)" onclick="@context.ToggleAsync" style="cursor:pointer">
                                <div class="status-dot"></div>
                                @StatusLabel(_issue.Status)
                                <MudIcon Icon="@Icons.Material.Outlined.ExpandMore" Style="font-size:12px; margin-left:2px" />
                            </div>
                        </ActivatorContent>
                        <ChildContent>
                            @foreach (IssueStatus s in Enum.GetValues<IssueStatus>())
                            {
                                <MudMenuItem OnClick="() => ChangeStatus(s)"
                                             Class="@(s == _issue.Status ? "menu-item-active" : "")">
                                    <div class="status-menu-item">
                                        <div class="status-dot-sm status-@StatusCss(s)"></div>
                                        @StatusLabel(s)
                                    </div>
                                </MudMenuItem>
                            }
                        </ChildContent>
                    </MudMenu>
                </div>

                <!-- Description -->
                <div class="section-block">
                    <div class="section-label">Description</div>
                    @if (_editingDescription)
                    {
                        <MudTextField @bind-Value="_descriptionDraft"
                                      Variant="Variant.Outlined"
                                      Lines="6"
                                      Placeholder="Describe the issue…"
                                      Class="description-field"
                                      Margin="Margin.Dense" />
                        <div class="desc-edit-actions">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="SaveDescription" Disabled="_savingDescription">
                                @(_savingDescription ? "Saving…" : "Save")
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                       OnClick="() => _editingDescription = false">
                                Cancel
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <div class="description-display @(string.IsNullOrWhiteSpace(_issue.Description) ? "desc-empty" : "")"
                             @onclick="StartEditDescription">
                            @if (string.IsNullOrWhiteSpace(_issue.Description))
                            {
                                <span>Add a description…</span>
                            }
                            else
                            {
                                @* In production, render Markdown here via a Markdown renderer *@
                                <p>@_issue.Description</p>
                            }
                        </div>
                    }
                </div>

                <!-- ── ACTIVITY LOG ─────────────────────────────────── -->
                <div class="section-block">
                    <div class="section-label">Activity</div>
                    <div class="activity-feed">
                        @if (!_activity.Any())
                        {
                            <div class="activity-empty">No activity recorded yet.</div>
                        }
                        else
                        {
                            @foreach (var entry in _activity)
                            {
                                <div class="activity-row">
                                    <div class="activity-avatar">
                                        @GetInitials(entry.ActorName)
                                    </div>
                                    <div class="activity-body">
                                        <div class="activity-line">
                                            <span class="activity-actor">@entry.ActorName</span>
                                            <span class="activity-verb">@entry.Verb</span>
                                            @if (!string.IsNullOrEmpty(entry.From))
                                            {
                                                <span class="activity-from">@entry.From</span>
                                                <span class="activity-arrow">→</span>
                                            }
                                            <span class="activity-to">@entry.To</span>
                                        </div>
                                        <div class="activity-time">@FormatRelative(entry.OccurredAt)</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- ── COMMENTS ─────────────────────────────────────── -->
                <div class="section-block">
                    <div class="section-label">
                        Comments
                        @if (_comments.Any())
                        {
                            <span class="comment-count">@_comments.Count</span>
                        }
                    </div>

                    <!-- Existing comments -->
                    @if (_comments.Any())
                    {
                        <div class="comments-list">
                            @foreach (var comment in _comments)
                            {
                                <div class="comment-row" @key="comment.Id">
                                    <div class="comment-avatar">
                                        @if (!string.IsNullOrEmpty(comment.AuthorAvatarUrl))
                                        {
                                            <img src="@comment.AuthorAvatarUrl" alt="@comment.AuthorDisplayName" class="avatar-img" />
                                        }
                                        else
                                        {
                                            <span>@GetInitials(comment.AuthorDisplayName)</span>
                                        }
                                    </div>
                                    <div class="comment-body">
                                        <div class="comment-header">
                                            <span class="comment-author">@comment.AuthorDisplayName</span>
                                            <span class="comment-time">@FormatRelative(comment.CreatedAt)</span>
                                            @if (comment.IsEdited)
                                            {
                                                <span class="comment-edited">(edited)</span>
                                            }
                                            @if (comment.AuthorId == _currentUserId)
                                            {
                                                <div class="comment-actions">
                                                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                                        Size="Size.Small"
                                                        OnClick="() => StartEditComment(comment)"
                                                        Class="comment-action-btn" />
                                                    <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                                        Size="Size.Small"
                                                        Color="Color.Error"
                                                        OnClick="() => ConfirmDeleteComment(comment)"
                                                        Class="comment-action-btn" />
                                                </div>
                                            }
                                        </div>

                                        @if (_editingCommentId == comment.Id)
                                        {
                                            <MudTextField @bind-Value="_commentEditDraft"
                                                Variant="Variant.Outlined"
                                                Lines="3"
                                                Margin="Margin.Dense"
                                                Class="comment-edit-field" />
                                            <div class="comment-edit-actions">
                                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                                    Size="Size.Small"
                                                    OnClick="() => SaveEditComment(comment)"
                                                    Disabled="_savingComment">
                                                    @(_savingComment ? "Saving…" : "Save")
                                                </MudButton>
                                                <MudButton Variant="Variant.Text" Color="Color.Default"
                                                    Size="Size.Small"
                                                    OnClick="CancelEditComment">
                                                    Cancel
                                                </MudButton>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="comment-text">@comment.Body</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- New comment composer -->
                    <div class="comment-composer">
                        <div class="composer-avatar">
                            @GetInitials(_currentUserName)
                        </div>
                        <div class="composer-input-wrap">
                            <MudTextField @bind-Value="_newCommentBody"
                                Placeholder="Leave a comment…"
                                Variant="Variant.Outlined"
                                Lines="3"
                                Margin="Margin.Dense"
                                Class="composer-field" />
                            <div class="composer-footer">
                                <div>
                                    @* <MudText Typo="Typo.caption" Class="mud-text-disabled">
                                        Markdown supported
                                    </MudText> *@
                                </div>
                                <MudButton Variant="Variant.Filled"
                                    Color="Color.Primary"
                                    Size="Size.Small"
                                    OnClick="SubmitComment"
                                    Disabled="@(string.IsNullOrWhiteSpace(_newCommentBody) || _savingComment)"
                                    Class="submit-comment-btn">
                                    @(_savingComment ? "Posting…" : "Comment")
                                </MudButton>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── RIGHT: Metadata sidebar ────────────────────────────── -->
            <aside class="issue-sidebar">

                <!-- Priority -->
                <div class="sidebar-field">
                    <div class="sidebar-label">Priority</div>
                    <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                        <ActivatorContent >
                            <MudButton Variant="Variant.Outlined" EndIcon="@Icons.Material.Outlined.ExpandMore" class="sidebar-value sidebar-clickable" OnClick="@context.ToggleAsync">
                                <div class="pri-dot pri-@PriorityCss(_issue.Priority)"></div>
                                <span style="margin-left:5px">
                                    @_issue.Priority.ToString()
                                </span>
                            </MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            @foreach (IssuePriority p in Enum.GetValues<IssuePriority>())
                            {
                                <MudMenuItem OnClick="() => ChangePriority(p)">
                                    <div class="pri-menu-item">
                                        <div class="pri-dot pri-@PriorityCss(p)"></div>
                                        @p.ToString()
                                    </div>
                                </MudMenuItem>
                            }
                        </ChildContent>
                    </MudMenu>
                </div>


                <!-- Assignee -->
                <div class="sidebar-field">
                    <div class="sidebar-label">Assignee</div>
                    <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                        <ActivatorContent>
                            <MudButton EndIcon="Icons.Material.Outlined.ExpandMore" class="sidebar-value sidebar-clickable" OnClick="@context.ToggleAsync">
                                @if (!string.IsNullOrEmpty(_issue.AssigneeDisplayName))
                                {
                                    <div class="assignee-avatar-sm">@GetInitials(_issue.AssigneeDisplayName)</div>
                                    <span style="margin-left:5px">@_issue.AssigneeDisplayName</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.PersonAdd" Style="font-size:15px; color:var(--mud-palette-text-disabled)" />
                                    <span style="margin-left:5px" class="sidebar-unset">Unassigned</span>
                                }
                            </MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem OnClick="() => ChangeAssignee(null, null)">
                                <div class="assignee-menu-item">
                                    <MudIcon Icon="@Icons.Material.Outlined.PersonOff" Style="font-size:15px" />
                                    Unassigned
                                </div>
                            </MudMenuItem>
                            <MudDivider />
                            @foreach (var m in _members)
                            {
                                <MudMenuItem OnClick="() => ChangeAssignee(m.UserId, m.DisplayName)">
                                    <div class="assignee-menu-item">
                                        <div class="assignee-avatar-sm">@GetInitials(m.DisplayName)</div>
                                        @m.DisplayName
                                    </div>
                                </MudMenuItem>
                            }
                        </ChildContent>
                    </MudMenu>
                </div>

                <!-- Due date -->
                <div class="sidebar-field">
                    <div class="sidebar-label">Due date</div>
                    <MudDatePicker Date="_issue.DueDate"
                        DateChanged="ChangeDueDate"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Clearable="true"
                        Placeholder="No due date"
                        Class="sidebar-datepicker" />
                </div>

                <!-- Labels -->
                <div class="sidebar-field">
                    <div class="sidebar-label">Labels</div>
                    <div class="labels-wrap">
                        @if (_issue.Labels.Any())
                        {
                            @foreach (var label in _issue.Labels)
                            {
                                <div class="label-chip" style="background:@label.Color+'22'; border-color:@label.Color+'44'; color:@label.Color">
                                    @label.Name
                                </div>
                            }
                        }
                        else
                        {
                            <span class="sidebar-unset">None</span>
                        }
                        <MudIconButton Icon="@Icons.Material.Outlined.Add"
                            Size="Size.Small"
                            Title="Add label"
                            Class="label-add-btn" />
                    </div>
                </div>

                <MudDivider Class="sidebar-divider" />

                <!-- Reporter -->
                <div class="sidebar-field">
                    <div class="sidebar-label">Reporter</div>
                    <div class="sidebar-value">
                        <div class="assignee-avatar-sm reporter-av">@GetInitials(_issue.ReporterDisplayName)</div>
                        <span>@_issue.ReporterDisplayName</span>
                    </div>
                </div>

                <!-- Created / Updated -->
                <div class="sidebar-field">
                    <div class="sidebar-label">Created</div>
                    <div class="sidebar-value sidebar-mono">@_issue.CreatedAt.ToString("MMM d, yyyy")</div>
                </div>
                <div class="sidebar-field">
                    <div class="sidebar-label">Updated</div>
                    <div class="sidebar-value sidebar-mono">@FormatRelative(_issue.UpdatedAt)</div>
                </div>

                <MudDivider Class="sidebar-divider" />

                <!-- Danger zone (Owners/Admins only) -->
                @if (_canManage)
                {
                    <div class="sidebar-field">
                        <MudButton Variant="Variant.Outlined"
                            Color="Color.Error"
                            Size="Size.Small"
                            StartIcon="@Icons.Material.Outlined.DeleteOutline"
                            FullWidth="true"
                            OnClick="ConfirmDeleteIssue"
                            Class="delete-issue-btn">
                            Delete issue
                        </MudButton>
                    </div>
                }

            </aside>
        </div>
    </div>
}

<!-- ── CONFIRM DIALOG ──────────────────────────────────────────────── -->
<MudDialog @bind-Visible="_confirmOpen" Options="_dialogSm">
    <TitleContent>
        <MudText Typo="Typo.h6">@_confirmTitle</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2">@_confirmBody</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _confirmOpen = false" Variant="Variant.Text" Color="Color.Default">Cancel</MudButton>
        <MudButton OnClick="ExecuteConfirm" Variant="Variant.Filled" Color="Color.Error"
                   Disabled="_confirmLoading">
            @if (_confirmLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>@_confirmActionLabel…</span>
            }
            else { <span>@_confirmActionLabel</span> }
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    /* ── LOADING ───────────────────────────────────────────────────────── */
    .issue-loading {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .skel {
        border-radius: 10px;
        background: var(--mud-palette-lines-default);
        animation: skel-pulse 1.6s ease-in-out infinite;
    }

    @@keyframes skel-pulse { 0%,100%{opacity:.4} 50%{opacity:.8} }

    .issue-layout  { display: grid; grid-template-columns: 1fr 280px; gap: 24px; }
    .skel-title    { height: 48px; width: 60%; }
    .skel-main     { height: 500px; }
    .skel-sidebar  { height: 500px; }

    /* ── NOT FOUND ─────────────────────────────────────────────────────── */
    .issue-not-found {
        max-width: 480px;
        margin: 80px auto;
        padding: 40px;
        text-align: center;
    }

    /* ── SHELL ─────────────────────────────────────────────────────────── */
    .issue-shell {
        max-width: 1100px;
        margin: 0 auto;
        padding: 24px 40px 80px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        animation: page-in 0.35s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes page-in {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── BREADCRUMB ────────────────────────────────────────────────────── */
    .issue-breadcrumb {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .bc-link {
        font-family: 'DM Mono', monospace;
        font-size: 12px !important;
        color: var(--mud-palette-text-disabled) !important;
        text-decoration: none !important;
        transition: color 0.15s;
    }

    .bc-link:hover { color: var(--mud-palette-primary) !important; }

    .bc-sep {
        font-size: 14px !important;
        color: var(--mud-palette-divider) !important;
    }

    .bc-current {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        color: var(--mud-palette-primary);
        font-weight: 600;
    }

    /* ── LAYOUT ────────────────────────────────────────────────────────── */
    .issue-layout {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 32px;
        align-items: flex-start;
    }

    /* ── MAIN PANEL ────────────────────────────────────────────────────── */
    .issue-main {
        display: flex;
        flex-direction: column;
        gap: 28px;
        min-width: 0;
    }

    /* Title */
    .issue-title-wrap {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        cursor: text;
        group: title;
    }

    .issue-title-wrap:hover .title-edit-icon { opacity: 1; }

    .issue-title {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(1.4rem, 2.5vw, 1.9rem);
        letter-spacing: -0.02em;
        line-height: 1.2;
        color: var(--mud-palette-text-primary);
        margin: 0;
        flex: 1;
    }

    .title-edit-icon {
        color: var(--mud-palette-text-disabled) !important;
        font-size: 16px !important;
        flex-shrink: 0;
        margin-top: 4px;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .title-edit-wrap { display: flex; flex-direction: column; gap: 8px; }
    .title-field .mud-input-outlined .mud-notched-outline { border-radius: 10px !important; }
    .title-edit-actions { display: flex; gap: 8px; }

    /* Tags row */
    .issue-tags-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: -12px;
    }

    .issue-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        padding: 3px 8px;
        border-radius: 99px;
    }

    .type-task    { background: rgba(37,99,235,0.1);  color: var(--mud-palette-info);    border: 1px solid rgba(37,99,235,0.2); }
    .type-bug     { background: rgba(220,38,38,0.1);  color: var(--mud-palette-error);   border: 1px solid rgba(220,38,38,0.2); }
    .type-feature { background: rgba(26,122,82,0.1);  color: var(--mud-palette-success); border: 1px solid rgba(26,122,82,0.2); }

    /* Status chip */
    .status-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        padding: 4px 10px;
        border-radius: 99px;
        border: 1px solid transparent;
        user-select: none;
    }

    .status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
    }

    .status-backlog    { background: var(--mud-palette-background-grey); color: var(--mud-palette-text-disabled); border-color: var(--mud-palette-divider); }
    .status-todo       { background: rgba(37,99,235,0.08);  color: var(--mud-palette-info);    border-color: rgba(37,99,235,0.2); }
    .status-inprogress { background: var(--mud-palette-primary-lighten); color: var(--mud-palette-primary); border-color: rgba(67,57,202,0.25); }
    .status-inreview   { background: rgba(217,119,6,0.1);   color: var(--mud-palette-warning); border-color: rgba(217,119,6,0.25); }
    .status-done       { background: rgba(26,122,82,0.1);   color: var(--mud-palette-success); border-color: rgba(26,122,82,0.2); }

    .status-dot-sm {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .status-menu-item, .pri-menu-item, .assignee-menu-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
    }

    .menu-item-active { background: var(--mud-palette-primary-lighten) !important; }

    /* ── SECTION BLOCKS ────────────────────────────────────────────────── */
    .section-block {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .section-label {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--mud-palette-text-disabled);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .comment-count {
        background: var(--mud-palette-lines-default);
        padding: 1px 6px;
        border-radius: 99px;
        font-size: 10px;
        color: var(--mud-palette-text-secondary);
    }

    /* Description */
    .description-display {
        font-size: 14px;
        color: var(--mud-palette-text-primary);
        line-height: 1.7;
        cursor: text;
        padding: 12px 14px;
        border: 1px solid transparent;
        border-radius: 10px;
        transition: border-color 0.15s, background 0.15s;
        min-height: 80px;
    }

    .description-display:hover {
        border-color: var(--mud-palette-divider);
        background: var(--mud-palette-background-grey);
    }

    .desc-empty { color: var(--mud-palette-text-disabled); font-style: italic; }

    .description-field .mud-input-outlined .mud-notched-outline { border-radius: 10px !important; }
    .desc-edit-actions { display: flex; gap: 8px; }

    /* ── ACTIVITY FEED ─────────────────────────────────────────────────── */
    .activity-feed {
        display: flex;
