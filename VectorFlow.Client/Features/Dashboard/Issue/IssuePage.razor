    }

    .label-chip {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        padding: 2px 8px;
        border-radius: 99px;
        border: 1px solid;
    }

    .label-add-btn { width: 22px !important; height: 22px !important; }

    /* Delete */
    .delete-issue-btn { border-radius: 8px !important; }

    /* ── RESPONSIVE ────────────────────────────────────────────────────── */
    @@media (max-width: 860px) {
        .issue-shell  { padding: 16px 16px 60px; }
        .issue-layout { grid-template-columns: 1fr; }
        .issue-sidebar { position: static; order: -1; }
        .skel-main, .skel-sidebar { height: 200px; }
