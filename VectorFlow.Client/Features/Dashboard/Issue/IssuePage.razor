</style>

@code {
    [Parameter] public string Slug       { get; set; } = string.Empty;
    [Parameter] public Guid   ProjectId  { get; set; }
    [Parameter] public Guid   IssueId    { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationState { get; set; }

    // ── Page state ─────────────────────────────────────────────────────
    private bool     _loading = true;
    private IssueDto? _issue;
    private string   _workspaceName  = string.Empty;
    private string   _projectName    = string.Empty;
    private string   _currentUserId  = string.Empty;
    private string   _currentUserName = string.Empty;
    private bool     _canManage; // Owner or Admin

    private List<CommentDto>  _comments = [];
    private List<ActivityRow> _activity = [];
    private List<WorkspaceMemberDto>   _members  = [];

    // Editing flags
    private bool   _editingTitle;
    private bool   _savingTitle;
    private string _titleDraft = string.Empty;

    private bool   _editingDescription;
    private bool   _savingDescription;
    private string _descriptionDraft = string.Empty;

    private Guid?  _editingCommentId;
    private bool   _savingComment;
    private string _commentEditDraft = string.Empty;
    private string _newCommentBody   = string.Empty;

    // Confirm dialog
    private bool   _confirmOpen;
    private bool   _confirmLoading;
    private string _confirmTitle       = string.Empty;
    private string _confirmBody        = string.Empty;
    private string _confirmActionLabel = string.Empty;
    private Func<Task>? _confirmAction;

    private readonly DialogOptions _dialogSm = new()
    {
        MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true
    };

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await Load();

    protected override async Task OnParametersSetAsync()
    {
        if (_issue is not null && _issue.Id != IssueId) await Load();
    }

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            if (AuthenticationState is null)
            {
                Snackbar.Add("User not found, please log in", Severity.Error);
                return;
            }

            var result = await DashboardService.GetDashboardIssueDataAsync(ProjectId,IssueId);
            if (result.Succeeded)
            {
                var user = (await AuthenticationState).User;
                _currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
                _currentUserName = user.FindFirst(ClaimTypes.Name)?.Value ?? "";

                _workspaceName = result.Data!.WorkspaceName;
                _canManage = result.Data.UserWorkspaceRole is WorkspaceRole.Owner or WorkspaceRole.Admin;
                _projectName = result.Data.ProjectName;
                _issue = result.Data.Issue;
                _comments = result.Data.Comments;
                _activity = result.Data.ActivityLogs.Select(MapActivity).ToList();
                _members = result.Data.Members;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load issue: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Title editing ──────────────────────────────────────────────────
    private void StartEditTitle()
    {
        _titleDraft   = _issue?.Title ?? string.Empty;
        _editingTitle = true;
    }

    private async Task SaveTitle()
    {
        if (_issue is null || string.IsNullOrWhiteSpace(_titleDraft)) return;
        try
        {
            _savingTitle = true;    
            var result = await IssueService.UpdateIssueAsync(ProjectId, IssueId, 
               new UpdateIssueRequest { Title = _titleDraft });
            if (result.Succeeded)
            {
                _editingTitle = false;
                _issue = result.Data!;
                Snackbar.Add("Issue title updated successfully",Severity.Success);
                return;
            }

            Snackbar.Add("Failed to update issue title",Severity.Error);
        }
        finally
        {
            _savingTitle  = false;  
        }
    }

    // ── Description editing ────────────────────────────────────────────
    private void StartEditDescription()
    {
        _descriptionDraft   = _issue?.Description ?? string.Empty;
        _editingDescription = true;
    }

    private async Task SaveDescription()
    {
        try
        {
            if (_issue is null || string.IsNullOrEmpty(_descriptionDraft)) return;
            _savingDescription = true;
            var result = await IssueService.UpdateIssueAsync(ProjectId, IssueId, 
                new UpdateIssueRequest { Description = _descriptionDraft });
            if (result.Succeeded)
            {
                _editingDescription = false;
                _issue = result.Data!;
                Snackbar.Add("Issue Description updated successfully",Severity.Success);
                return;
            }

            Snackbar.Add("Failed to update issue description",Severity.Error);
        }
        finally
        {
            _savingDescription  = false;
        }
    }

    // ── Status change ──────────────────────────────────────────────────
    private async Task ChangeStatus(IssueStatus newStatus)
    {
        if (_issue is null || newStatus == _issue.Status) return;
        var old = _issue.Status;
        var result = await IssueService.UpdateIssueStatusAsync(ProjectId, IssueId, 
            new UpdateIssueStatusRequest { Status = newStatus });
        var log = new ActivityRow(_currentUserName, ActivityAction.StatusChanged, StatusLabel(old), StatusLabel(newStatus), DateTime.UtcNow);
        if (result.Succeeded)
        {
            _issue = result.Data!;
            Snackbar.Add("Issue status updated successfully",Severity.Success);
            AddOptimisticActivity(log);
            return;
        }

        UndoOptimisticActivity(log);
        Snackbar.Add("Failed to update issue status",Severity.Error);
    }

    // ── Priority change ────────────────────────────────────────────────
    private async Task ChangePriority(IssuePriority newPriority)
    {
        if (_issue is null || newPriority == _issue.Priority) return;
        var old = _issue.Priority;
        var result = await IssueService.UpdateIssueAsync(ProjectId, IssueId, 
            new UpdateIssueRequest { Priority = newPriority });
        var log = new ActivityRow(_currentUserName, ActivityAction.StatusChanged, old.ToString(), newPriority.ToString(), DateTime.UtcNow);
        if (result.Succeeded)
        {
            _issue = result.Data!;
            Snackbar.Add("Issue priority updated successfully",Severity.Success);
            AddOptimisticActivity(log);
            return;
        }

        UndoOptimisticActivity(log);
        Snackbar.Add("Failed to update issue priority",Severity.Error);
    }

    // ── Assignee change ────────────────────────────────────────────────
    private async Task ChangeAssignee(string? userId, string? displayName)
    {
        if (_issue is null) return;
        var old = _issue.AssigneeDisplayName;
        var result = await IssueService.UpdateIssueAssigneeAsync(ProjectId, IssueId, 
            new UpdateIssueAssigneeRequest { AssigneeId = userId });
        var log = new ActivityRow(_currentUserName, ActivityAction.AssigneeChanged, old ?? "Unassigned", displayName ?? "Unassigned", DateTime.UtcNow);
        if (result.Succeeded)
        {
            _issue = result.Data!;
            var action = !string.IsNullOrEmpty(userId) ? "set" : "removed";
            Snackbar.Add($"Issue assignee {action} successfully",Severity.Success);
            AddOptimisticActivity(log);
            return;
        }

        UndoOptimisticActivity(log);
        Snackbar.Add("Failed to change assignee",Severity.Error);
    }

    // ── Due date change ────────────────────────────────────────────────
    private async Task ChangeDueDate(DateTime? newDate)
    {
        if (_issue is null) return;
        var old = _issue.DueDate;
        var result = await IssueService.UpdateIssueDueDateAsync(ProjectId, IssueId, 
            new UpdateIssueDueDateRequest { DueDate = newDate });
        var log = new ActivityRow(_currentUserName, ActivityAction.DueDateChanged, old?.ToString("yyyy-MM-dd") ?? "Unscheduled", newDate?.ToString("yyyy-MM-dd") ?? "Unscheduled", DateTime.UtcNow);
        if (result.Succeeded)
        {
            _issue = result.Data!;
            var action = newDate != null ? "updated" : "removed";
            Snackbar.Add($"Issue DueDate {action} successfully", Severity.Success);
            AddOptimisticActivity(log);
            return;
        }

        UndoOptimisticActivity(log);
        Snackbar.Add("Failed to update issue DueDate",Severity.Error);
    }

    // ── Comments ───────────────────────────────────────────────────────
    private async Task SubmitComment()
    {
        if (string.IsNullOrWhiteSpace(_newCommentBody)) return;
        _savingComment = true;
        try 
        {
            var result = await CommentService.CreateCommentAsync(IssueId,
                new CreateCommentRequest {Body = _newCommentBody});
            
            if (result.Succeeded) 
            {
                _comments.Add(result.Data!);
                _newCommentBody = string.Empty;
                return;
            }

            Snackbar.Add(result.Error ?? "Failed to create comment",Severity.Error);
        }
        finally
        {
            _savingComment  = false;
        }
    }

    private void StartEditComment(CommentDto comment)
    {
        _editingCommentId = comment.Id;
        _commentEditDraft = comment.Body;
    }

    private void CancelEditComment()
    {
        _editingCommentId = null;
        _commentEditDraft = string.Empty;
    }

    private async Task SaveEditComment(CommentDto comment)
    {
        if (string.IsNullOrWhiteSpace(_commentEditDraft)) return;
        _savingComment = true;
        try 
        {
           var result = await CommentService.UpdateCommentAsync(comment.Id,
                 new UpdateCommentRequest { Body = _commentEditDraft });

            if (result.Succeeded) 
            {
                var idx = _comments.IndexOf(comment);
                if (idx >= 0) _comments[idx] = result.Data!;
                _editingCommentId = null;
                Snackbar.Add("Comment updated successfully", Severity.Success);
                return;
            }

            Snackbar.Add(result.Error ?? "Failed to update comment",Severity.Error);
        }
        finally
        {
            _savingComment    = false;
        }
    }

    private void ConfirmDeleteComment(CommentDto comment) =>
        ShowConfirm("Delete comment?", "This comment will be permanently removed.",
            "Delete",
            async () =>
            {
                // TODO: await CommentService.DeleteAsync(comment.Id);
                await Task.Delay(400);
                _comments.Remove(comment);
            });

    // ── Delete issue ───────────────────────────────────────────────────
    private void ConfirmDeleteIssue() =>
        ShowConfirm($"Delete {_issue?.Key}?",
            "This permanently deletes the issue, all its comments, and its activity log.",
            "Delete issue",
            async () =>
            {
                // TODO: await IssueService.DeleteAsync(ProjectId, IssueId);
                await Task.Delay(600);
                Nav.NavigateTo($"/w/{Slug}/projects/{ProjectId}");
            });

    // ── Confirm helper ─────────────────────────────────────────────────
    private void ShowConfirm(string title, string body, string action, Func<Task> onConfirm)
    {
        _confirmTitle       = title;
        _confirmBody        = body;
        _confirmActionLabel = action;
        _confirmAction      = onConfirm;
        _confirmOpen        = true;
    }

    private async Task ExecuteConfirm()
    {
        if (_confirmAction is null) return;
        _confirmLoading = true;
        try   { await _confirmAction(); }
        finally { _confirmLoading = false; _confirmOpen = false; _confirmAction = null; }
    }

    // ── Optimistic activity push ───────────────────────────────────────
    private void AddOptimisticActivity(ActivityRow log) => _activity.Insert(0, log);

    private void UndoOptimisticActivity(ActivityRow log) => _activity.Remove(log);
       
    // ── Display helpers ────────────────────────────────────────────────
    private static string StatusCss(IssueStatus s) => s switch
    {
        IssueStatus.InProgress => "inprogress",
        IssueStatus.InReview   => "inreview",
        _                      => s.ToString().ToLower()
    };

    private static string StatusLabel(IssueStatus s) => s switch
    {
        IssueStatus.InProgress => "In Progress",
        IssueStatus.InReview   => "In Review",
        _                      => s.ToString()
    };

    private static string PriorityCss(IssuePriority p) => p.ToString().ToLower();

    private static string TypeIcon(IssueType t) => t switch
    {
        IssueType.Bug     => Icons.Material.Outlined.BugReport,
        IssueType.Feature => Icons.Material.Outlined.Stars,
        _                 => Icons.Material.Outlined.CheckBox
    };

    private static string FormatRelative(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt.ToUniversalTime();
        if (diff.TotalMinutes < 1)  return "just now";
        if (diff.TotalHours < 1)    return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1)     return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7)     return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("MMM d, yyyy");
    }

    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    // ── Activity row model ─────────────────────────────────────────────
    private sealed record ActivityRow(
        string   ActorName,
        ActivityAction   Verb,
        string   From,
        string   To,
        DateTime OccurredAt
    );

    private ActivityRow MapActivity(ActivityLogDto log)
    {
        return new ActivityRow(
            log.ActorDisplayName, 
            log.Action, 
            log.FromValue ?? "", 
            log.ToValue ?? "", 
            log.CreatedAt);
    }
}
