    .sidebar-field:last-child { border-bottom: none; padding-bottom: 0; }
    .sidebar-field:first-child { padding-top: 0; }

    .sidebar-label {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
