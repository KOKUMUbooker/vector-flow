
<div class="auth-panel">
        <a href = "/" class="panel-brand">VectorFlow</a>

        <div class="panel-body">
            <div class="panel-kicker">New password</div>
            <p class="panel-headline">Make it<br />a good one.</p>

            <!-- Password rules -->
            <div class="rules-list">
                <div class="rule-item @(HasLength ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>At least 8 characters</span>
                </div>
                <div class="rule-item @(HasUpper ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>One uppercase letter</span>
                </div>
                <div class="rule-item @(HasNumber ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>One number</span>
                </div>
                <div class="rule-item @(HasSpecial ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>One special character</span>
                </div>
            </div>
        </div>

        <div class="panel-footer">
            <div class="security-badge">
                <MudIcon Icon = "@Icons.Material.Outlined.Shield" Style="font-size:14px; color: var(--mud-palette-success);" />
                <span>Token-validated, single-use link</span>
            </div>
        </div>
</div>

<style>
/* LEFT */
.auth-panel {
    background: var(--mud-palette-dark, #0D0D0F);
    color: var(--mud-palette-white);
    display: flex;
    flex-direction: column;
    padding: 40px 48px;
    position: relative;
    overflow: hidden;
}

.auth-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(var(--mud-palette-primary) 1px, transparent 1px),
        linear-gradient(90deg, var(--mud-palette-primary) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.04;
    pointer-events: none;
}

.auth-panel::after {
    content: '';
    position: absolute;
    bottom: -60px;
    left: -60px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--mud-palette-success) 0%, transparent 65%);
    opacity: 0.06;
    pointer-events: none;
}

.panel-brand {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.25rem;
    color: var(--mud-palette-white);
    text-decoration: none;
    position: relative;
    z-index: 1;
}

.panel-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 1;
}

.panel-kicker {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--mud-palette-success);
    margin-bottom: 16px;
}

.panel-headline {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--mud-palette-white);
    margin: 0 0 36px;
}

/* Password rules */
.rules-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.rule-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    transition: color 0.25s;
    animation: feed-in 0.4s ease both;
}

.rule-item:nth-child(1) { animation-delay: 0.1s; }
.rule-item:nth-child(2) { animation-delay: 0.2s; }
.rule-item:nth-child(3) { animation-delay: 0.3s; }
.rule-item:nth-child(4) { animation-delay: 0.4s; }

@@keyframes feed-in {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
}

.rule-pass { color: var(--mud-palette-success) !important; }

.rule-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.2);
    background: transparent;
    flex-shrink: 0;
    transition: all 0.25s;
}

.rule-pass .rule-dot {
    background: var(--mud-palette-success);
    border-color: var(--mud-palette-success);
}

.panel-footer {
    position: relative;
    z-index: 1;
}

.security-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    padding: 8px 12px;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 8px;
    background: rgba(26,122,82,0.06);
}
</style>

@code {
    [Parameter, EditorRequired]
    public bool HasLength { get; set; }

    [Parameter, EditorRequired]
    public bool HasUpper { get; set; }

    [Parameter, EditorRequired]
    public bool HasNumber { get; set; }

    [Parameter, EditorRequired]
    public bool HasSpecial { get; set; }
}