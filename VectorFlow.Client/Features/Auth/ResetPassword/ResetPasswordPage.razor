@page "/reset-password"
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Reset password — VectorFlow</PageTitle>

<div class="auth-shell">

    <!-- LEFT PANEL -->
    <div class="auth-panel">
        <a href="/" class="panel-brand">VectorFlow</a>

        <div class="panel-body">
            <div class="panel-kicker">New password</div>
            <p class="panel-headline">Make it<br />a good one.</p>

            <!-- Password rules -->
            <div class="rules-list">
                <div class="rule-item @(HasLength ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>At least 8 characters</span>
                </div>
                <div class="rule-item @(HasUpper ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>One uppercase letter</span>
                </div>
                <div class="rule-item @(HasNumber ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>One number</span>
                </div>
                <div class="rule-item @(HasSpecial ? "rule-pass" : "")">
                    <div class="rule-dot"></div>
                    <span>One special character</span>
                </div>
            </div>
        </div>

        <div class="panel-footer">
            <div class="security-badge">
                <MudIcon Icon="@Icons.Material.Outlined.Shield" Style="font-size:14px; color: var(--mud-palette-success);" />
                <span>Token-validated, single-use link</span>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="auth-form-side">
        <div class="auth-form-card">

            @if (_tokenMissing)
            {
                <div class="form-header">
                    <div class="form-icon-wrap form-icon-error">
                        <MudIcon Icon="@Icons.Material.Outlined.LinkOff" Class="form-icon-err" />
                    </div>
                    <MudText Typo="Typo.h3" Class="form-title">Invalid reset link</MudText>
                    <MudText Typo="Typo.body2" Class="form-subtitle">
                        This link is missing a token. Please request a new reset link.
                    </MudText>
                </div>
                <MudButton Href="/forgot-password"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Class="submit-btn">
                    Request new link
                </MudButton>
            }
            else if (_resetComplete)
            {
                <div class="success-state">
                    <div class="success-ring">
                        <MudIcon Icon="@Icons.Material.Outlined.LockOpen" Class="success-icon" />
                    </div>
                    <MudText Typo="Typo.h4" Class="form-title mt-6 mb-2">Password updated</MudText>
                    <MudText Typo="Typo.body2" Class="form-subtitle mb-6">
                        Your password has been reset successfully. You can now sign in with your new credentials.
                    </MudText>
                    <MudButton Href="/login"
                        Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Large"
                        FullWidth="true"
                        Class="submit-btn">
                        Sign in to VectorFlow
                    </MudButton>
                </div>
            }
            else
            {
                <div class="form-header">
                    <div class="form-icon-wrap">
                        <MudIcon Icon="@Icons.Material.Outlined.Lock" Class="form-icon" />
                    </div>
                    <MudText Typo="Typo.h3" Class="form-title">Set new password</MudText>
                    <MudText Typo="Typo.body2" Class="form-subtitle">
                        Choose a strong password for your VectorFlow account.
                    </MudText>
                </div>

                <MudForm @ref="_form" @bind-IsValid="_isValid" Class="auth-mud-form">

                    <div class="field-group">
                        <label class="field-label">New password</label>
                        <MudTextField @bind-Value="_model.NewPassword"
                            Placeholder="At least 8 characters"
                            InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Required="true"
                            RequiredError="Password is required"
                            Validation="@ValidatePassword"
                            Class="auth-field"
                            Adornment="Adornment.End"
                            AdornmentIcon="@(_showPassword ? Icons.Material.Outlined.VisibilityOff : Icons.Material.Outlined.Visibility)"
                            OnAdornmentClick="() => _showPassword = !_showPassword"
                            AdornmentColor="Color.Default"
                            @bind-Value:after="OnPasswordChanged" />

                        <!-- Strength meter -->
                        @if (!string.IsNullOrEmpty(_model.NewPassword))
                        {
                            <div class="strength-meter">
                                <div class="strength-track">
                                    @for (int i = 0; i < 4; i++)
                                    {
                                        var filled = i < _passwordStrength;
                                        <div class="strength-seg @(filled ? $"strength-{_passwordStrength}" : "")"></div>
                                    }
                                </div>
                                <span class="strength-label" style="color:@_strengthColor">@_strengthLabel</span>
                            </div>
                        }
                    </div>

                    <div class="field-group">
                        <label class="field-label">Confirm new password</label>
                        <MudTextField @bind-Value="_confirmPassword"
                            Placeholder="••••••••"
                            InputType="@(_showConfirm ? InputType.Text : InputType.Password)"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Required="true"
                            RequiredError="Please confirm your password"
                            Validation="@ValidateConfirm"
                            Class="auth-field"
                            Adornment="Adornment.End"
                            AdornmentIcon="@(_showConfirm ? Icons.Material.Outlined.VisibilityOff : Icons.Material.Outlined.Visibility)"
                            OnAdornmentClick="() => _showConfirm = !_showConfirm"
                            AdornmentColor="Color.Default" />
                    </div>

                    <MudButton OnClick="HandleReset"
                        Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Large"
                        FullWidth="true"
                        Disabled="_loading"
                        Class="submit-btn">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Updating password…</span>
                        }
                        else
                        {
                            <span>Reset password</span>
                        }
                    </MudButton>

                </MudForm>
            }

            @if (!_resetComplete && !_tokenMissing)
            {
                <MudDivider Class="my-6" />
                <div class="back-link">
                    <MudButton Href="/login"
                        Variant="Variant.Text"
                        Color="Color.Default"
                        StartIcon="@Icons.Material.Outlined.ArrowBack"
                        Class="back-btn">
                        Back to sign in
                    </MudButton>
                </div>
            }

        </div>
    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    .auth-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    /* LEFT */
    .auth-panel {
        background: var(--mud-palette-dark, #0D0D0F);
        color: var(--mud-palette-white);
        display: flex;
        flex-direction: column;
        padding: 40px 48px;
        position: relative;
        overflow: hidden;
    }

    .auth-panel::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(var(--mud-palette-primary) 1px, transparent 1px),
            linear-gradient(90deg, var(--mud-palette-primary) 1px, transparent 1px);
        background-size: 48px 48px;
        opacity: 0.04;
        pointer-events: none;
    }

    .auth-panel::after {
        content: '';
        position: absolute;
        bottom: -60px;
        left: -60px;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, var(--mud-palette-success) 0%, transparent 65%);
        opacity: 0.06;
        pointer-events: none;
    }

    .panel-brand {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 1.25rem;
        color: var(--mud-palette-white);
        text-decoration: none;
        position: relative;
        z-index: 1;
    }

    .panel-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 1;
    }

    .panel-kicker {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--mud-palette-success);
        margin-bottom: 16px;
    }

    .panel-headline {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(2rem, 3vw, 3rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--mud-palette-white);
        margin: 0 0 36px;
    }

    /* Password rules */
    .rules-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .rule-item {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        color: rgba(255,255,255,0.4);
        transition: color 0.25s;
        animation: feed-in 0.4s ease both;
    }

    .rule-item:nth-child(1) { animation-delay: 0.1s; }
    .rule-item:nth-child(2) { animation-delay: 0.2s; }
    .rule-item:nth-child(3) { animation-delay: 0.3s; }
    .rule-item:nth-child(4) { animation-delay: 0.4s; }

    @@keyframes feed-in {
        from { opacity: 0; transform: translateX(-8px); }
        to   { opacity: 1; transform: translateX(0); }
    }

    .rule-pass { color: var(--mud-palette-success) !important; }

    .rule-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1.5px solid rgba(255,255,255,0.2);
        background: transparent;
        flex-shrink: 0;
        transition: all 0.25s;
    }

    .rule-pass .rule-dot {
        background: var(--mud-palette-success);
        border-color: var(--mud-palette-success);
    }

    .panel-footer {
        position: relative;
        z-index: 1;
    }

    .security-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: rgba(255,255,255,0.3);
        padding: 8px 12px;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 8px;
        background: rgba(26,122,82,0.06);
    }

    /* RIGHT */
    .auth-form-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 48px;
        background: var(--mud-palette-background);
    }

    .auth-form-card {
        width: 100%;
        max-width: 400px;
        animation: card-rise 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes card-rise {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .form-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--mud-palette-primary-lighten);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .form-icon-error { background: rgba(220,38,38,0.1) !important; }
    .form-icon     { color: var(--mud-palette-primary) !important; font-size: 24px !important; }
    .form-icon-err { color: var(--mud-palette-error)   !important; font-size: 24px !important; }

    .form-header   { margin-bottom: 32px; }
    .form-title    { letter-spacing: -0.02em !important; margin-bottom: 6px !important; color: var(--mud-palette-text-primary) !important; }
    .form-subtitle { color: var(--mud-palette-text-secondary) !important; }

    .auth-mud-form { display: flex; flex-direction: column; gap: 20px; }
    .field-group   { display: flex; flex-direction: column; gap: 6px; }

    .field-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        font-family: 'DM Sans', system-ui, sans-serif;
    }

    .auth-field .mud-input-outlined .mud-notched-outline { border-radius: 10px !important; }

    /* Strength */
    .strength-meter {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 6px;
    }

    .strength-track { display: flex; gap: 4px; flex: 1; }

    .strength-seg {
        flex: 1;
        height: 3px;
        border-radius: 99px;
        background: var(--mud-palette-lines-default);
        transition: background 0.25s;
    }

    .strength-seg.strength-1 { background: var(--mud-palette-error); }
    .strength-seg.strength-2 { background: var(--mud-palette-warning); }
    .strength-seg.strength-3 { background: var(--mud-palette-info); }
    .strength-seg.strength-4 { background: var(--mud-palette-success); }

    .strength-label {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        width: 48px;
        text-align: right;
        transition: color 0.25s;
    }

    /* Success */
    .success-state { text-align: center; }

    .success-ring {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(26,122,82,0.1);
        border: 2px solid var(--mud-palette-success);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        animation: ring-pop 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes ring-pop {
        from { transform: scale(0.7); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }

    .success-icon { color: var(--mud-palette-success) !important; font-size: 32px !important; }

    .submit-btn {
        border-radius: 10px !important;
        height: 48px !important;
        font-size: 14px !important;
        letter-spacing: 0 !important;
    }

    .back-btn  { border-radius: 8px !important; }
    .back-link { text-align: center; }

    @@media (max-width: 768px) {
        .auth-shell     { grid-template-columns: 1fr; }
        .auth-panel     { display: none; }
        .auth-form-side { padding: 40px 24px; min-height: 100vh; }
    }
</style>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading;
    private bool _showPassword;
    private bool _showConfirm;
    private bool _resetComplete;
    private bool _tokenMissing;
    private string _confirmPassword = string.Empty;

    private int _passwordStrength;
    private string _strengthLabel = string.Empty;
    private string _strengthColor = string.Empty;

    private PasswordResetDto _model = new()
    {
        PasswordVerificationToken = string.Empty,
        NewPassword = string.Empty
    };

    // Live rule checks bound to left-panel indicators
    private bool HasLength  => _model.NewPassword.Length >= 8;
    private bool HasUpper   => _model.NewPassword.Any(char.IsUpper);
    private bool HasNumber  => _model.NewPassword.Any(char.IsDigit);
    private bool HasSpecial => _model.NewPassword.Any(c => !char.IsLetterOrDigit(c));

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("token", out var token) && !string.IsNullOrWhiteSpace(token))
        {
            _model = new PasswordResetDto
            {
                PasswordVerificationToken = token.ToString(),
                NewPassword = string.Empty
            };
        }
        else
        {
            _tokenMissing = true;
        }
    }

    private void OnPasswordChanged()
    {
        var pw = _model.NewPassword;
        if (string.IsNullOrEmpty(pw)) { _passwordStrength = 0; return; }

        int score = 0;
        if (pw.Length >= 8)            score++;
        if (pw.Length >= 12)           score++;
        if (HasSpecial)                score++;
        if (HasNumber && HasUpper)     score++;

        _passwordStrength = Math.Max(1, score);

        (_strengthLabel, _strengthColor) = _passwordStrength switch
        {
            1 => ("Weak",   "var(--mud-palette-error)"),
            2 => ("Fair",   "var(--mud-palette-warning)"),
            3 => ("Good",   "var(--mud-palette-info)"),
            _ => ("Strong", "var(--mud-palette-success)")
        };
    }

    private string? ValidatePassword(string pw)
    {
        if (string.IsNullOrWhiteSpace(pw)) return "Password is required";
        if (pw.Length < 8) return "Must be at least 8 characters";
        return null;
    }

    private string? ValidateConfirm(string confirm)
    {
        if (confirm != _model.NewPassword) return "Passwords do not match";
        return null;
    }

    private async Task HandleReset()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _loading = true;
        StateHasChanged();

        // TODO: await AuthService.ResetPasswordAsync(_model);
        await Task.Delay(1400);

        _loading = false;
        _resetComplete = true;
    }

    public class PasswordResetDto
    {
        [System.ComponentModel.DataAnnotations.Required]
        public required string PasswordVerificationToken { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public required string NewPassword { get; set; }
    }
}
