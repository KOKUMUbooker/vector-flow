<div class="auth-panel">
    <a href="/" class="panel-brand">VectorFlow</a>

    <div class="panel-body">
        <div class="panel-kicker">Account recovery</div>
        <p class="panel-headline">Happens to<br />everyone.</p>

        <div class="info-cards">
            <div class="info-card">
                <div class="info-icon">📬</div>
                <div>
                    <div class="info-title">Check your inbox</div>
                    <div class="info-desc">We'll send a secure reset link to your email address.</div>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon">⏱</div>
                <div>
                    <div class="info-title">Link expires in 1 hour</div>
                    <div class="info-desc">For security, reset links are single-use and time-limited.</div>
                </div>
            </div>
                 
        </div>
    </div>

    <div class="panel-footer">
        <div class="terminal-line">
            <span class="terminal-prompt">vf</span>
            <span class="terminal-cmd">auth reset --email &lt;you@company.com&gt;</span>
        </div>
        <div class="terminal-line terminal-response">
            <span>✓ Reset link dispatched</span>
        </div>
    </div>
</div>

<style>
