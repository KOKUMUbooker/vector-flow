@page "/forgot-password"
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IClientAuthService ClientAuthService
@using System.ComponentModel.DataAnnotations
@using VectorFlow.Client.Features.Auth.ForgotPassword.Components
@using VectorFlow.Client.Services.Interfaces
@using VectorFlow.Shared.DTOs

<PageTitle>Forgot password — VectorFlow</PageTitle>

<div class="auth-shell">

    <!-- LEFT PANEL -->
    <LeftPanel/>
   
    <!-- RIGHT PANEL -->
    <div class="auth-form-side">
        <div class="auth-form-card">

            @if (!_emailSent)
            {
                <div class="form-header">
                    <div class="form-icon-wrap">
                        <MudIcon Icon="@Icons.Material.Outlined.LockReset" Class="form-icon" />
                    </div>
                    <MudText Typo="Typo.h3" Class="form-title">Reset your password</MudText>
                    <MudText Typo="Typo.body2" Class="form-subtitle">
                        Enter your account email and we'll send you a link to get back in.
                    </MudText>
                </div>

                <MudForm @ref="_form" @bind-IsValid="_isValid" Class="auth-mud-form">

                    <div class="field-group">
                        <label class="field-label">Account email</label>
                        <MudTextField @bind-Value="_model.Email"
                            Placeholder="you@company.com"
                            InputType="InputType.Email"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Required="true"
                            RequiredError="Email is required"
                            Validation="@(new EmailAddressAttribute() { ErrorMessage = "Enter a valid email address" })"
                            Class="auth-field"
                            Adornment="Adornment.Start"
                            AdornmentIcon="@Icons.Material.Outlined.AlternateEmail"
                            AdornmentColor="Color.Default" />
                    </div>

                    <MudButton OnClick="HandleForgotPassword"
                        Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Large"
                        FullWidth="true"
                        Disabled="_loading"
                        Class="submit-btn">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Sending link…</span>
                        }
                        else
                        {
                            <span>Send reset link</span>
                        }
                    </MudButton>

                </MudForm>
            }
            else
            {
                <!-- Success state -->
                <div class="success-state">
                    <div class="success-ring">
                        <MudIcon Icon="@Icons.Material.Outlined.MarkEmailRead" Class="success-icon" />
                    </div>
                    <MudText Typo="Typo.h4" Class="form-title mt-6 mb-2">Check your email</MudText>
                    <MudText Typo="Typo.body2" Class="form-subtitle mb-6">
                        We sent a reset link to <strong>@_model.Email</strong>.
                        It expires in 1 hour — check your spam folder if it doesn't arrive.
                    </MudText>

                    <MudButton OnClick="HandleResend"
                        Variant="Variant.Text"
                        Color="Color.Primary"
                        Disabled="_resendLoading"
                        Class="mb-2 resend-btn">
                        @if (_resendLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Resending…</span>
                        }
                        else
                        {
                            <span>Resend email</span>
                        }
                    </MudButton>

                    @if (_resendCooldown > 0)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-disabled">
                            Resend available in @_resendCooldown s
                        </MudText>
                    }
                </div>
            }

            <MudDivider Class="my-6" />

            <div class="back-link">
                <MudButton Href="/login"
                    Variant="Variant.Text"
                    Color="Color.Default"
                    StartIcon="@Icons.Material.Outlined.ArrowBack"
                    Class="back-btn">
                    Back to sign in
                </MudButton>
            </div>

        </div>
    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    .auth-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    /* RIGHT */
    .auth-form-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 48px;
        background: var(--mud-palette-background);
    }

    .auth-form-card {
        width: 100%;
        max-width: 400px;
        animation: card-rise 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes card-rise {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .form-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--mud-palette-primary-lighten);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .form-icon {
        color: var(--mud-palette-primary) !important;
        font-size: 24px !important;
    }

    .form-header { margin-bottom: 32px; }

    .form-title {
        letter-spacing: -0.02em !important;
        margin-bottom: 6px !important;
        color: var(--mud-palette-text-primary) !important;
    }

    .form-subtitle { color: var(--mud-palette-text-secondary) !important; }

    .auth-mud-form { display: flex; flex-direction: column; gap: 20px; }

    .field-group { display: flex; flex-direction: column; gap: 6px; }

    .field-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        font-family: 'DM Sans', system-ui, sans-serif;
        letter-spacing: 0.01em;
    }

    .auth-field .mud-input-outlined .mud-notched-outline { border-radius: 10px !important; }

    .submit-btn {
        border-radius: 10px !important;
        height: 48px !important;
        font-size: 14px !important;
        letter-spacing: 0 !important;
    }

    /* Success state */
    .success-state { text-align: center; }

    .success-ring {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(26,122,82,0.1);
        border: 2px solid var(--mud-palette-success);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        animation: ring-pop 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes ring-pop {
        from { transform: scale(0.7); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }

    .success-icon { color: var(--mud-palette-success) !important; font-size: 32px !important; }

    .resend-btn { border-radius: 8px !important; }
    .back-btn   { border-radius: 8px !important; }
    .back-link  { text-align: center; }

    @@media (max-width: 768px) {
        .auth-shell { grid-template-columns: 1fr; }
        .auth-panel { display: none; }
        .auth-form-side { padding: 40px 24px; min-height: 100vh; }
    }
</style>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading;
    private bool _emailSent;
    private bool _resendLoading;
    private int _resendCooldown;

    private readonly ForgotPasswordDto _model = new ForgotPasswordDto() { Email = string.Empty };

    private async Task HandleForgotPassword()
    {
        try
        {
            await _form.ValidateAsync();
            if (!_isValid) return;

            _loading = true;
            StateHasChanged();

            var result = await ClientAuthService.ForgotPasswordAsync(_model);
            if (result.Succeeded)
            {
                Snackbar.Add(result.Message, Severity.Success);
                _emailSent = true;
                return;
            }
    
            Snackbar.Add(
                result.Errors.Any() 
                    ? result.Errors.ElementAt(0) : 
                    "Failed to send password reset link", 
                Severity.Error);
            StartResendCooldown();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleResend()
    {
        if (_resendCooldown > 0) return;
        _resendLoading = true;
        StateHasChanged();

        await ClientAuthService.ForgotPasswordAsync(_model);

        _resendLoading = false;
        Snackbar.Add("Reset link resent!", Severity.Info);
        StartResendCooldown();
    }

    private async void StartResendCooldown()
    {
        _resendCooldown = 60;
        while (_resendCooldown > 0)
        {
            await Task.Delay(1000);
            _resendCooldown--;
            StateHasChanged();
        }
    }
}
