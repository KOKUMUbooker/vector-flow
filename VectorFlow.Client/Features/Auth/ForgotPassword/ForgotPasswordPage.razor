@page "/forgot-password"
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using System.ComponentModel.DataAnnotations

<PageTitle>Forgot password — VectorFlow</PageTitle>

<div class="auth-shell">

    <!-- LEFT PANEL -->
    <div class="auth-panel">
        <a href="/" class="panel-brand">VectorFlow</a>

        <div class="panel-body">
            <div class="panel-kicker">Account recovery</div>
            <p class="panel-headline">Happens to<br />everyone.</p>

            <div class="info-cards">
                <div class="info-card">
                    <div class="info-icon">📬</div>
                    <div>
                        <div class="info-title">Check your inbox</div>
                        <div class="info-desc">We'll send a secure reset link to your email address.</div>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-icon">⏱</div>
                    <div>
                        <div class="info-title">Link expires in 1 hour</div>
                        <div class="info-desc">For security, reset links are single-use and time-limited.</div>
                    </div>
                </div>
                 
            </div>
        </div>

        <div class="panel-footer">
            <div class="terminal-line">
                <span class="terminal-prompt">vf</span>
                <span class="terminal-cmd">auth reset --email &lt;you@company.com&gt;</span>
            </div>
            <div class="terminal-line terminal-response">
                <span>✓ Reset link dispatched</span>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="auth-form-side">
        <div class="auth-form-card">

            @if (!_emailSent)
            {
                <div class="form-header">
                    <div class="form-icon-wrap">
                        <MudIcon Icon="@Icons.Material.Outlined.LockReset" Class="form-icon" />
                    </div>
                    <MudText Typo="Typo.h3" Class="form-title">Reset your password</MudText>
                    <MudText Typo="Typo.body2" Class="form-subtitle">
                        Enter your account email and we'll send you a link to get back in.
                    </MudText>
                </div>

                <MudForm @ref="_form" @bind-IsValid="_isValid" Class="auth-mud-form">

                    <div class="field-group">
                        <label class="field-label">Account email</label>
                        <MudTextField @bind-Value="_model.Email"
                                      Placeholder="you@company.com"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Required="true"
                                      RequiredError="Email is required"
                                      Validation="@(new EmailAddressAttribute() { ErrorMessage = "Enter a valid email address" })"
                                      Class="auth-field"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Outlined.AlternateEmail"
                                      AdornmentColor="Color.Default" />
                    </div>

                    <MudButton OnClick="HandleForgotPassword"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               FullWidth="true"
                               Disabled="_loading"
                               Class="submit-btn">
                        @if (_loading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Sending link…</span>
                        }
                        else
                        {
                            <span>Send reset link</span>
                        }
                    </MudButton>

                </MudForm>
            }
            else
            {
                <!-- Success state -->
                <div class="success-state">
                    <div class="success-ring">
                        <MudIcon Icon="@Icons.Material.Outlined.MarkEmailRead" Class="success-icon" />
                    </div>
                    <MudText Typo="Typo.h4" Class="form-title mt-6 mb-2">Check your email</MudText>
                    <MudText Typo="Typo.body2" Class="form-subtitle mb-6">
                        We sent a reset link to <strong>@_model.Email</strong>.
                        It expires in 1 hour — check your spam folder if it doesn't arrive.
                    </MudText>

                    <MudButton OnClick="HandleResend"
                               Variant="Variant.Text"
                               Color="Color.Primary"
                               Disabled="_resendLoading"
                               Class="mb-2 resend-btn">
                        @if (_resendLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Resending…</span>
                        }
                        else
                        {
                            <span>Resend email</span>
                        }
                    </MudButton>

                    @if (_resendCooldown > 0)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-disabled">
                            Resend available in @_resendCooldown s
                        </MudText>
                    }
                </div>
            }

            <MudDivider Class="my-6" />

            <div class="back-link">
                <MudButton Href="/login"
                           Variant="Variant.Text"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Outlined.ArrowBack"
                           Class="back-btn">
                    Back to sign in
                </MudButton>
            </div>

        </div>
    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@@0;1&family=DM+Mono:wght@@400;500&family=DM+Sans:wght@@300;400;500;600&display=swap');

    .auth-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    /* LEFT */
    .auth-panel {
        background: var(--mud-palette-dark, #0D0D0F);
        color: var(--mud-palette-white);
        display: flex;
        flex-direction: column;
        padding: 40px 48px;
        position: relative;
        overflow: hidden;
    }

    .auth-panel::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(var(--mud-palette-primary) 1px, transparent 1px),
            linear-gradient(90deg, var(--mud-palette-primary) 1px, transparent 1px);
        background-size: 48px 48px;
        opacity: 0.04;
        pointer-events: none;
    }

    .auth-panel::after {
        content: '';
        position: absolute;
        top: 40%;
        left: -120px;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, var(--mud-palette-warning) 0%, transparent 65%);
        opacity: 0.06;
        pointer-events: none;
    }

    .panel-brand {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 1.25rem;
        color: var(--mud-palette-white);
        text-decoration: none;
        position: relative;
        z-index: 1;
    }

    .panel-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 1;
    }

    .panel-kicker {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--mud-palette-warning);
        margin-bottom: 16px;
    }

    .panel-headline {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(2rem, 3vw, 3rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--mud-palette-white);
        margin: 0 0 40px;
    }

    /* Info cards */
    .info-cards {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .info-card {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 10px;
        padding: 14px 16px;
        animation: feed-in 0.4s ease both;
    }

    .info-card:nth-child(1) { animation-delay: 0.1s; }
    .info-card:nth-child(2) { animation-delay: 0.2s; }
    .info-card:nth-child(3) { animation-delay: 0.3s; }

    @@keyframes feed-in {
        from { opacity: 0; transform: translateX(-10px); }
        to   { opacity: 1; transform: translateX(0); }
    }

    .info-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
    .info-title { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.9); margin-bottom: 2px; }
    .info-desc  { font-size: 12px; color: rgba(255,255,255,0.4); line-height: 1.4; }

    /* Terminal */
    .panel-footer { position: relative; z-index: 1; }

    .terminal-line {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 0;
    }

    .terminal-prompt {
        color: var(--mud-palette-primary);
        font-weight: 600;
    }

    .terminal-cmd { color: rgba(255,255,255,0.5); }

    .terminal-response {
        color: var(--mud-palette-success);
        padding-left: 32px;
        animation: blink-in 0.4s ease 1s both;
    }

    @@keyframes blink-in {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    /* RIGHT */
    .auth-form-side {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 48px;
        background: var(--mud-palette-background);
    }

    .auth-form-card {
        width: 100%;
        max-width: 400px;
        animation: card-rise 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes card-rise {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .form-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--mud-palette-primary-lighten);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .form-icon {
        color: var(--mud-palette-primary) !important;
        font-size: 24px !important;
    }

    .form-header { margin-bottom: 32px; }

    .form-title {
        letter-spacing: -0.02em !important;
        margin-bottom: 6px !important;
        color: var(--mud-palette-text-primary) !important;
    }

    .form-subtitle { color: var(--mud-palette-text-secondary) !important; }

    .auth-mud-form { display: flex; flex-direction: column; gap: 20px; }

    .field-group { display: flex; flex-direction: column; gap: 6px; }

    .field-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
        font-family: 'DM Sans', system-ui, sans-serif;
        letter-spacing: 0.01em;
    }

    .auth-field .mud-input-outlined .mud-notched-outline { border-radius: 10px !important; }

    .submit-btn {
        border-radius: 10px !important;
        height: 48px !important;
        font-size: 14px !important;
        letter-spacing: 0 !important;
    }

    /* Success state */
    .success-state { text-align: center; }

    .success-ring {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(26,122,82,0.1);
        border: 2px solid var(--mud-palette-success);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        animation: ring-pop 0.5s cubic-bezier(.4,0,.2,1) both;
    }

    @@keyframes ring-pop {
        from { transform: scale(0.7); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }

    .success-icon { color: var(--mud-palette-success) !important; font-size: 32px !important; }

    .resend-btn { border-radius: 8px !important; }
    .back-btn   { border-radius: 8px !important; }
    .back-link  { text-align: center; }

    @@media (max-width: 768px) {
        .auth-shell { grid-template-columns: 1fr; }
        .auth-panel { display: none; }
        .auth-form-side { padding: 40px 24px; min-height: 100vh; }
    }
</style>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading;
    private bool _emailSent;
    private bool _resendLoading;
    private int _resendCooldown;

    private readonly ForgotPasswordDto _model = new() { Email = string.Empty };

    private async Task HandleForgotPassword()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _loading = true;
        StateHasChanged();

        // TODO: await AuthService.ForgotPasswordAsync(_model);
        await Task.Delay(1200);

        _loading = false;
        _emailSent = true;
        StartResendCooldown();
    }

    private async Task HandleResend()
    {
        if (_resendCooldown > 0) return;
        _resendLoading = true;
        StateHasChanged();

        // TODO: await AuthService.ForgotPasswordAsync(_model);
        await Task.Delay(1000);

        _resendLoading = false;
        Snackbar.Add("Reset link resent!", Severity.Info);
        StartResendCooldown();
    }

    private async void StartResendCooldown()
    {
        _resendCooldown = 60;
        while (_resendCooldown > 0)
        {
            await Task.Delay(1000);
            _resendCooldown--;
            StateHasChanged();
        }
    }

    public class ForgotPasswordDto
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public required string Email { get; set; }
    }
}
