@page "/"

@using VectorFlow.Client.Features.Home.components
@using VectorFlow.Client.Features.Layout

<PageTitle>Vector Flow - Lightweight Project Management for Small Teams</PageTitle>

<MudMainContent>
    <!-- Hero Section -->
   <HeroSection/>

    <!-- Stats Section -->
   <StatsSection/>

    <!-- Features Grid -->
   <FeaturesSection/>

    <!-- Value Proposition Section -->
    <ValuePropositionSetction/>
 
    <!-- CTA Section -->
    <CTASection/>

    <!-- Footer -->
    <Footer/>
</MudMainContent>

<style>
.landing-appbar {
  background-color: transparent !important;
  position: sticky;
  top: 0;
  z-index: 100;
}

.hero-section {
  padding: 120px 0 80px 0;
}

.hero-title {
  font-size: 3.5rem;
  line-height: 1.2;
}

.hero-subtitle {
  max-width: 600px;
  margin: 0 auto;
}

.stats-section {
  padding: 60px 0;
}

.features-section {
  padding: 80px 0;
}

.feature-card {
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease;
  height: 100%;
  border-radius: 12px;
}

.feature-card:hover {
  transform: translateY(-4px);
}

.value-paper {
  border-radius: 16px;
}

.value-card {
  transition:
    transform 0.3s ease,
    box-shadow 0.3s ease;
}

.value-card:hover {
  transform: translateY(-4px);
}

.cta-section {
  padding: 100px 0 80px 0;
}

.footer-section {
  padding: 40px 0 60px 0;
}

.gap-2 {
  gap: 8px;
}

.gap-3 {
  gap: 12px;
}

.gap-4 {
  gap: 16px;
}

.gap-6 {
  gap: 24px;
}

.mt-12 {
  margin-top: 48px;
}

.mb-12 {
  margin-bottom: 48px;
}

@@media (max-width: 960px) {
  .hero-title {
    font-size: 2rem;
  }

  .hero-section {
    padding: 80px 0 40px 0;
  }

  .features-section {
    padding: 40px 0;
  }
}
</style>