@page "/"
@using VectorFlow.Client.Features.Home.components
@using VectorFlow.Client.Features.Layout
@inject NavigationManager Nav

<PageTitle>VectorFlow — Issue Tracking for Dev Teams That Move Fast</PageTitle>

<!-- HERO SECTION -->
<HeroSection/>

<!-- FEATURES SECTION -->
<FeaturesSection/>

<!-- HOW IT WORKS SECTION -->
<HowItWorks/>

<!-- TECH STACK SECTION -->
<TechStackSection/>

<!-- ROLES SECTION -->
<RolesSection/>

<!-- CTA SECTION -->
<CTASection/>

<!-- FOOTER -->
<Footer/>

<style>
    /* Base styles for typography */
    :root {
        --vf-serif: 'DM Serif Display', Georgia, serif;
        --vf-mono: 'DM Mono', monospace;
    }
    
    /* Navigation */
    .vf-navbar {
        backdrop-filter: blur(12px);
        background: rgba(var(--mud-palette-background-rgb), 0.88) !important;
        border-bottom: 1px solid var(--mud-palette-lines-default);
    }
    
    .nav-brand {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .nav-logo {
        background: var(--mud-palette-primary) !important;
        color: white !important;
    }
    
    .nav-links {
        display: flex;
        align-items: center;
        gap: 28px;
    }
    
    .nav-link {
        font-weight: 500;
        transition: color 0.15s;
    }
    
    .nav-link:hover {
        color: var(--mud-palette-primary);
    }
    
    .nav-cta-btn {
        margin-left: 8px;
    }
     
    /* Sections */
    .section {
        padding: 80px 16px;
    }
    
    .section-label {
        margin-bottom: 12px;
    }
    
    .section-sub {
        margin-top: 12px;
        max-width: 520px;
    }
    
    
    /* Responsive */
    @@media (max-width: 960px) {
        .hero-container {
            padding: 60px 16px 40px !important;
        }
        
        .section {
            padding: 60px 16px;
        }
        
        .how-section,
        .roles-section,
        .cta-section {
            padding: 60px 0;
        }
        
        .features-grid {
            grid-template-columns: 1fr;
        }
        
        .steps {
            grid-template-columns: 1fr 1fr;
        }
        
        .stack-grid {
            grid-template-columns: 1fr;
        }
        
        .roles-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
