@page "/"
@using VectorFlow.Client.Features.Home.components
@using VectorFlow.Client.Features.Layout
@inject NavigationManager Nav

<PageTitle>VectorFlow — Issue Tracking for Dev Teams That Move Fast</PageTitle>

<!-- HERO SECTION -->
<HeroSection/>

<!-- FEATURES SECTION -->
<FeaturesSection/>

<!-- HOW IT WORKS SECTION -->
<HowItWorks/>

<!-- TECH STACK SECTION -->
<TechStackSection/>

<!-- ROLES SECTION -->
<RolesSection/>

<!-- CTA SECTION -->
<CTASection/>

<!-- FOOTER -->
<Footer/>

<style>
    /* Base styles for typography */
    :root {
        --vf-serif: 'DM Serif Display', Georgia, serif;
        --vf-mono: 'DM Mono', monospace;
    }
    
    /* Sections */
    .section {
        padding: 80px 16px;
    }
    
    .section-label {
        margin-bottom: 12px;
    }
    
    .section-sub {
        margin-top: 12px;
        max-width: 520px;
    }
    
    
    /* Responsive */
    @@media (max-width: 960px) {
        .hero-container {
            padding: 60px 16px 40px !important;
        }
        
        .section {
            padding: 60px 16px;
        }
        
        .how-section,
        .roles-section,
        .cta-section {
            padding: 60px 0;
        }
        
        .features-grid {
            grid-template-columns: 1fr;
        }
        
        .steps {
            grid-template-columns: 1fr 1fr;
        }
        
        .stack-grid {
            grid-template-columns: 1fr;
        }
        
        .roles-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
