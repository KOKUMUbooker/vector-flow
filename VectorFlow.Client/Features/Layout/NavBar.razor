@using System.Security.Claims
@using Microsoft.Extensions.Identity.Core
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using VectorFlow.Client.Services
@using VectorFlow.Client.Services.Interfaces
@using VectorFlow.Client.Theme
@using System.Text.Json   
@inject ThemeService ThemeService
@inject NavigationManager Nav
@inject IClientAuthService AuthService
@inject ISnackbar Snackbar
@implements IDisposable

<MudAppBar Elevation="0" Class="vf-appbar">
    <MudContainer MaxWidth="@(_isAuthenticated ? MaxWidth.ExtraLarge : MaxWidth.Large)"
                  Class="d-flex align-center justify-space-between px-0">

        <!-- Brand — always visible -->
        <a href="/" class="vf-brand">
            <div class="vf-logo">VF</div>
            <span class="vf-brand-name d-none d-sm-flex">VectorFlow</span>
        </a>

        <AuthorizeView>

            <!-- AUTHENTICATED NAV -->
            <Authorized Context="authState">


                @* @if (!string.IsNullOrEmpty(_currentWorkspace))
                {
                    <div class="workspace-crumb">
                        <MudIcon Icon="@Icons.Material.Outlined.GridView" Style="font-size:14px; opacity:0.5;" />
                        <span class="crumb-text"
                              @onclick="@(() => Nav.NavigateTo($"/w/{_currentWorkspaceSlug}"))">
                            @_currentWorkspace
                        </span>
                        @if (!string.IsNullOrEmpty(_currentProject))
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.ChevronRight" Style="font-size:14px; opacity:0.4;" />
                            <span class="crumb-text crumb-active">@_currentProject</span>
                        }
                    </div>
                }
                else
                {
                    <div></div>
                } *@

                <div class="d-none d-md-flex align-center">
                    <MudNavLink href="/dashboard"
                             class="vf-nav-link"
                             Match="NavLinkMatch.Prefix"
                             Ripple="false"
                             ActiveClass="vf-nav-link-active">
                             <div style="display:flex; flex-direction:row; align-items: center">
                                <MudIcon Icon="@Icons.Material.Outlined.Dashboard"
                                         Size="Size.Small"
                                         Class="mr-1" />
                                Dashboard
                             </div>
                    </MudNavLink>

                    <MudNavLink href="/workspaces"
                             class="vf-nav-link"
                             Match="NavLinkMatch.Prefix"
                             Ripple="false"
                             ActiveClass="vf-nav-link-active">
                             <div style="display:flex; flex-direction:row; align-items: center">
                                <MudIcon Icon="@Icons.Material.Outlined.WorkOutline"
                                         Size="Size.Small"
                                         Class="mr-1" />
                                Workspaces
                            </div>
                    </MudNavLink>

                    <MudNavLink href="/invitations"
                             class="vf-nav-link"
                             Ripple="false"
                             Match="NavLinkMatch.Prefix"
                             ActiveClass="vf-nav-link-active">
                             <div style="display:flex; flex-direction:row; align-items: center">
                                <MudIcon Icon="@Icons.Material.Outlined.Mail"
                                         Size="Size.Small"
                                         Class="mr-1" />
                                Invitations
                            </div>
                    </MudNavLink>
                </div>

                <div class="d-flex align-center gap-2">
                    <MudTooltip Text="@(_isDarkMode ? "Light mode" : "Dark mode")">
                        <MudIconButton
                            Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                            OnClick="ToggleTheme" Size="Size.Small" Color="Color.Default" />
                    </MudTooltip>

                    <MudDivider Vertical="true" FlexItem="true" Style="height:20px; align-self:center;" Class="mx-1" />

                @{
                    var user = authState.User; // use authState from Authorized component as its reactive

                    var displayName =
                        user.FindFirstValue(ClaimTypes.Name) ?? "";

                    var email =
                        user.FindFirstValue(ClaimTypes.Email) ?? "";

                    var initials = GetInitials(displayName);
                    _isAuthenticated = !string.IsNullOrEmpty(email);
                }
                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                        <ActivatorContent >
                            <MudAvatar>
                            <div  @onclick="@context.ToggleAsync" class="user-avatar" title="@displayName">@initials</div>
                            </MudAvatar>
                        </ActivatorContent>
                        <ChildContent >
                            <div class="user-menu-header">
                                <div class="user-menu-avatar">@initials</div>
                                <div class="user-menu-info">
                                    <div class="user-menu-name">@displayName</div>
                                    <div class="user-menu-email">@email</div>
                                </div>
                            </div>
                            <MudDivider Class="my-1" />
                            <MudMenuItem Icon="@Icons.Material.Outlined.Dashboard"
                                         OnClick="@(() => Nav.NavigateTo("/dashboard"))">
                                Dashboard
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Outlined.WorkOutline"
                                         OnClick="@(() => Nav.NavigateTo("/workspaces"))">
                                My workspaces
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Outlined.MarkEmailUnread"
                                         OnClick="@(() => Nav.NavigateTo("/invitations"))">
                                Invitations
                            </MudMenuItem>
                            <MudDivider Class="my-1" />
                            <MudMenuItem Icon="@(_isDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                                         OnClick="ToggleTheme">
                                @(_isDarkMode ? "Light mode" : "Dark mode")
                            </MudMenuItem>
                            <MudDivider Class="my-1" />
                            <MudMenuItem Icon="@Icons.Material.Outlined.Logout"
                                         OnClick="HandleLogout"
                                         Style="color: var(--mud-palette-error);">
                                Sign out
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </div>
            </Authorized>

            <!-- UNAUTHENTICATED NAV -->
            <NotAuthorized>
                <div class="d-none d-md-flex align-center gap-6">
                    <MudLink Href="/#features" Underline="Underline.None" Class="vf-nav-link">Features</MudLink>
                    <MudLink Href="/#how" Underline="Underline.None" Class="vf-nav-link">How it works</MudLink>
                    <MudLink Href="/#roles" Underline="Underline.None" Class="vf-nav-link">Roles</MudLink>
                </div>
                <div class="d-flex align-center gap-2">
                    <MudIconButton
                        Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                        OnClick="ToggleTheme" Size="Size.Medium" Color="Color.Default" />
                    <MudDivider Vertical="true" FlexItem="true" Style="height:24px; align-self:center;" Class="mx-1" />
                    <MudButton Href="/login" Variant="Variant.Text" Color="Color.Primary" Class="d-none d-sm-flex">
                        Sign in
                    </MudButton>
                    <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" Class="vf-cta-btn">
                        Get started
                    </MudButton>
                </div>
            </NotAuthorized>

            <!-- LOADING -->
            <Authorizing>
                <div class="nav-loading">
                    <div class="nav-skel nav-skel-sm"></div>
                    <div class="nav-skel nav-skel-lg"></div>
                </div>
            </Authorizing>

        </AuthorizeView>
    </MudContainer>
</MudAppBar>

<style>
    .vf-appbar {
        background-color: rgba(var(--mud-palette-background-rgb), 0.88) !important;
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--mud-palette-divider) !important;
        transition: background-color 0.2s ease;
        z-index: 100;
    }
    .vf-brand {
        text-decoration: none !important;
        display: flex; align-items: center; gap: 10px; flex-shrink: 0;
    }
    .vf-brand-name {
        font-family: 'DM Serif Display', Georgia, serif !important;
        font-size: 1.1rem !important;
        color: var(--mud-palette-text-primary) !important;
        font-weight: 400 !important;
    }
    .vf-logo {
        width: 32px; height: 32px;
        background: var(--mud-palette-primary); border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        color: white; font-family: 'DM Mono', monospace;
        font-size: 12px; font-weight: 500; flex-shrink: 0;
    }
    .vf-nav-link {
        font-size: 14px !important; font-weight: 500 !important;
        color: var(--mud-palette-text-secondary) !important;
        transition: color 0.15s !important;
    }
    .vf-nav-link:hover { color: var(--mud-palette-primary) !important; }
    .vf-cta-btn {
        font-size: 14px !important; font-weight: 600 !important;
        text-transform: none !important; border-radius: 8px !important;
        padding: 6px 18px !important;
    }

    .vf-nav-link-active {
        color: var(--mud-palette-primary);
        font-weight: 600;
    }
    .workspace-crumb {
        display: flex; align-items: center; gap: 6px;
        font-family: 'DM Mono', monospace; font-size: 12px;
        color: var(--mud-palette-text-secondary);
    }
    .crumb-text {
        cursor: pointer; transition: color 0.15s; white-space: nowrap;
        overflow: hidden; text-overflow: ellipsis; max-width: 160px;
    }
    .crumb-text:hover { color: var(--mud-palette-primary); }
    .crumb-active { color: var(--mud-palette-text-primary); font-weight: 500; cursor: default; }
    .crumb-active:hover { color: var(--mud-palette-text-primary); }
    .user-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--mud-palette-primary); color: white;
        font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: opacity 0.15s; flex-shrink: 0; user-select: none;
    }
    .user-avatar:hover { opacity: 0.85; }
    .user-menu-header {
        display: flex; align-items: center; gap: 12px; padding: 12px 16px 8px;
    }
    .user-menu-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: var(--mud-palette-primary); color: white;
        font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 600;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .user-menu-name { font-size: 13px; font-weight: 600; color: var(--mud-palette-text-primary); white-space: nowrap; }
    .user-menu-email { font-size: 11px; color: var(--mud-palette-text-disabled); font-family: 'DM Mono', monospace; white-space: nowrap; }
    .nav-loading { display: flex; align-items: center; gap: 8px; margin-left: auto; }
    .nav-skel { height: 28px; border-radius: 6px; background: var(--mud-palette-lines-default); animation: nav-skel-pulse 1.4s ease-in-out infinite; }
    .nav-skel-sm { width: 32px; border-radius: 50%; }
    .nav-skel-lg { width: 80px; }
    @@keyframes nav-skel-pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 0.8; } }
    .gap-2 { gap: 8px; }
    .gap-6 { gap: 24px; }
</style>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private bool   _isDarkMode;
    private bool   _isAuthenticated;
    private string _currentWorkspace    = string.Empty;
    private string _currentWorkspaceSlug = string.Empty;
    private string _currentProject      = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _isDarkMode = ThemeService.IsDarkMode;
        ThemeService.OnThemeChanged += HandleThemeChanged;
        Nav.LocationChanged += OnLocationChanged;

        await ResolveAuthStateAsync();
        ParseRouteContext(Nav.Uri);
    }

    private async Task ResolveAuthStateAsync()
    {
        if (AuthenticationState is null) return;
        var state = await AuthenticationState;
        var user  = state.User;
        _isAuthenticated = user.Identity?.IsAuthenticated == true;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        ParseRouteContext(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void ParseRouteContext(string uri)
    {
        _currentWorkspace     = string.Empty;
        _currentWorkspaceSlug = string.Empty;
        _currentProject       = string.Empty;

        var path = new Uri(uri).AbsolutePath.TrimStart('/');
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length >= 2 && segments[0] == "w")
        {
            _currentWorkspaceSlug = segments[1];
            _currentWorkspace     = FormatSlug(segments[1]);
        }
        if (segments.Length >= 4 && segments[2] == "projects")
        {
            // Replace with real project name lookup once ProjectService is wired
            _currentProject = "Project";
        }
    }

    private static string FormatSlug(string slug) =>
        System.Globalization.CultureInfo.CurrentCulture.TextInfo
            .ToTitleCase(slug.Replace("-", " "));

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
        Snackbar.Add("You've been signed out.", Severity.Info,
            cfg => cfg.VisibleStateDuration = 2000);
    }

    private void ToggleTheme() => ThemeService.Toggle();

    private void HandleThemeChanged()
    {
        _isDarkMode = ThemeService.IsDarkMode;
        InvokeAsync(StateHasChanged);
    }

    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
        Nav.LocationChanged        -= OnLocationChanged;
    }
}
